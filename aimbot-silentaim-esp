-- FONKSİYONLAR (%100 ÇALIŞIR)
local function colorOf(plr)
    local dn = (plr.DisplayName or plr.Name):lower() or ""
    if dn:find("sheriff") then return Color3.fromRGB(58,135,238) end
    if dn:find("killer") or dn:find("katil") or dn:find("murder") then return Color3.fromRGB(215,44,77) end
    if dn:find("masum") or dn:find("innocent") then return Color3.fromRGB(27,221,65) end
    return Color3.fromRGB(255,255,255)
end
local function addESP(plr)
    if plr~=LocalPlayer and plr.Character and plr.Character:FindFirstChild("Head") and not plr.Character.Head:FindFirstChild("MYESP_TAG") then
        local bb=Instance.new("BillboardGui",plr.Character.Head)
        bb.Name="MYESP_TAG"
        bb.AlwaysOnTop=true
        bb.Size=UDim2.new(0,110,0,38)
        local lbl=Instance.new("TextLabel",bb)
        lbl.TextSize=16
        lbl.TextStrokeTransparency=.33
        lbl.Font=Enum.Font.GothamBold
        lbl.Size=UDim2.new(1,0,1,0)
        lbl.BackgroundTransparency=.4
        lbl.BackgroundColor3=colorOf(plr)
        lbl.TextColor3=Color3.fromRGB(255,255,255)
        lbl.BorderSizePixel=0
        lbl.Text=(plr.DisplayName or plr.Name)
    end
end
local function removeESP(plr)
    if plr.Character and plr.Character:FindFirstChild("Head") and plr.Character.Head:FindFirstChild("MYESP_TAG") then
        plr.Character.Head.MYESP_TAG:Destroy()
    end
end
local function updateESP()
    for _,plr in ipairs(Players:GetPlayers()) do
        if states.esp then addESP(plr) else removeESP(plr) end
    end
end
Players.PlayerAdded:Connect(function(plr)
    plr.CharacterAdded:Connect(function() wait(0.4) if states.esp then addESP(plr) end end)
end)
for _,plr in ipairs(Players:GetPlayers()) do
    if plr~=LocalPlayer then
        plr.CharacterAdded:Connect(function() wait(0.4) if states.esp then addESP(plr) end end)
    end
end

-- EN YAKIN DÜŞMAN
local function getAimbotTarget()
    local mv = UserInputService:GetMouseLocation()
    local min_dist,closest = math.huge,nil
    for _,plr in ipairs(Players:GetPlayers()) do
        if plr~=LocalPlayer and plr.Character and plr.Character:FindFirstChild("Head") and plr.Character:FindFirstChildOfClass("Humanoid") and plr.Character.Humanoid.Health>0 then
            local pos,vis = Camera:WorldToViewportPoint(plr.Character.Head.Position)
            if vis then
                local dist = (Vector2.new(pos.X,pos.Y)-mv).Magnitude
                if dist < min_dist and dist < 230 then
                    min_dist,closest = dist,plr
                end
            end
        end
    end
    return closest
end

RunService.RenderStepped:Connect(function()
    pcall(updateESP)
    if states.aimbot then
        local tar=getAimbotTarget()
        if tar and tar.Character and tar.Character:FindFirstChild("Head") then
            local cam = workspace.CurrentCamera
            cam.CFrame = CFrame.new(cam.CFrame.Position, tar.Character.Head.Position)
        end
    end
end)

local rawmt = getrawmetatable and getrawmetatable(game) or getmetatable(game)
local _namecall = rawmt.__namecall
setreadonly(rawmt,false)
rawmt.__namecall = newcclosure(function(self,...)
    local args = {...}
    if states.silentaim and tostring(self)=="Hit" then
        local tar=getAimbotTarget()
        if tar and tar.Character and tar.Character:FindFirstChild("Head") then
            args[1] = tar.Character.Head.Position
            return _namecall(self,unpack(args))
        end
    end
    return _namecall(self,...)
end)
setreadonly(rawmt,true)

