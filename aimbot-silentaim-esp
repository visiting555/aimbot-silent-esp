-----------------------------------------
-- ENEMY / CLOSEST KONTROLLERİ
-----------------------------------------
local function isEnemy(p)
    if p == LocalPlayer then return false end
    if p.Team ~= nil and LocalPlayer.Team ~= nil then
        return p.Team ~= LocalPlayer.Team
    end
    return true
end

local function getClosestEnemy()
    local mouse = UIS:GetMouseLocation()
    local dist, closest = math.huge, nil
    for _, v in ipairs(Players:GetPlayers()) do
        if isEnemy(v) and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            local pos, onScreen = Camera:WorldToViewportPoint(v.Character.HumanoidRootPart.Position)
            if onScreen then
                local d = (Vector2.new(pos.X, pos.Y) - Vector2.new(mouse.X, mouse.Y)).Magnitude
                if d < dist then
                    dist = d
                    closest = v
                end
            end
        end
    end
    return closest
end

-----------------------------------------
-- FONK: AIMBOT
-----------------------------------------
local function aimAt(target)
    if not target or not target.Character or not target.Character:FindFirstChild("HumanoidRootPart") then return end
    local targetPos = target.Character.HumanoidRootPart.Position
    Camera.CFrame = CFrame.new(Camera.CFrame.Position, targetPos)
end

-----------------------------------------
-- FONK: SILENTAIM
-----------------------------------------
local SilentAimTarget = nil
local OldNamecall
OldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    if not checkcaller() then
        local method = getnamecallmethod()
        if cheats["SilentAim"] and SilentAimTarget and tostring(method) == "FindPartOnRayWithIgnoreList" then
            local args = {...}
            if SilentAimTarget.Character and SilentAimTarget.Character:FindFirstChild("Head") then
                local camPos = Camera.CFrame.Position
                args[1] = Ray.new(camPos, (SilentAimTarget.Character.Head.Position-camPos).Unit*500)
                return OldNamecall(self, unpack(args))
            end
        end
    end
    return OldNamecall(self, ...)
end)

-----------------------------------------
-- FONK: ESP (BILLBOARDGUI İLE)
-----------------------------------------
local espBoxes = {}
local function clearESP()
    for _, g in ipairs(espBoxes) do if g and g.Parent then g:Destroy() end end
    espBoxes = {}
end

local function createESPBox(part, col, size)
    local gui = Instance.new("BillboardGui")
    gui.Adornee = part
    gui.Size = size or UDim2.new(0,80,0,110)
    gui.AlwaysOnTop = true
    gui.Parent = game.CoreGui

    local box = Instance.new("Frame")
    box.Parent = gui
    box.Size = UDim2.new(1,0,1,0)
    box.BorderSizePixel = 2
    box.BorderColor3 = col
    box.BackgroundColor3 = col
    box.BackgroundTransparency = 0.75
    return gui
end

local function addESP(player)
    if not player.Character then return end
    local hrp = player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local main = createESPBox(hrp, Color3.fromRGB(255, 64, 64), UDim2.new(0,80,0,110))
    table.insert(espBoxes, main)
    local leftLeg = player.Character:FindFirstChild("LeftLowerLeg") or player.Character:FindFirstChild("Left Leg")
    local rightLeg = player.Character:FindFirstChild("RightLowerLeg") or player.Character:FindFirstChild("Right Leg")
    if leftLeg then table.insert(espBoxes, createESPBox(leftLeg, Color3.fromRGB(242,239,69), UDim2.new(0,18,0,40))) end
    if rightLeg then table.insert(espBoxes, createESPBox(rightLeg, Color3.fromRGB(242,239,69), UDim2.new(0,18,0,40))) end
end

local function updateESP()
    clearESP()
    if not cheats.ESP then return end
    for _, p in ipairs(Players:GetPlayers()) do
        if isEnemy(p) then
            addESP(p)
        end
    end
end

Players.PlayerAdded:Connect(function(plr)
    plr.CharacterAdded:Connect(function() updateESP() end)
end)
Players.PlayerRemoving:Connect(function() updateESP() end)

