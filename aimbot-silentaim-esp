-- Option Toggle Creation
local yBase = 58
local optionHeight, gap = 42, 15
local toggles = {}

local function makeToggle(text, key, order)
    local Toggle = Instance.new("TextButton")
    Toggle.Name = key .. "_Btn"
    Toggle.Size = UDim2.new(0.92,0,0,optionHeight)
    Toggle.Position = UDim2.new(0.04, 0, 0, yBase + (optionHeight+gap)*(order-1))
    Toggle.Font = Enum.Font.GothamBold
    Toggle.TextSize = 21
    Toggle.Text = text .. ": OFF"
    Toggle.BackgroundColor3 = Color3.new(0,0,0)
    Toggle.TextColor3 = Color3.new(1,1,1)
    Toggle.AutoButtonColor = false
    Toggle.BorderSizePixel = 0
    Toggle.Parent = MenuFrame

    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 13)
    btnCorner.Parent = Toggle

    Toggle.MouseEnter:Connect(function()
        Toggle.BackgroundColor3 = Color3.fromRGB(36,36,36)
    end)
    Toggle.MouseLeave:Connect(function()
        Toggle.BackgroundColor3 = Color3.new(0,0,0)
    end)
    Toggle.MouseButton1Click:Connect(function()
        settings[key] = not settings[key]
        Toggle.Text = text .. ": " .. (settings[key] and "ON" or "OFF")
        if key == "ESP" and not settings[key] then
            clearEsp()
        end
    end)

    table.insert(toggles, Toggle)
    return Toggle
end

