-- Buton - Toggle
local function addToggle(text, ypos, setting)
    local btn = Instance.new("TextButton")
    btn.Parent = frame
    btn.Size = UDim2.new(0,210,0,30)
    btn.Position = UDim2.new(0,18,0,ypos)
    btn.BackgroundColor3 = settings[setting] and Color3.fromRGB(39,81,44) or Color3.fromRGB(40,40,45)
    btn.Text = text..": "..(settings[setting] and "AÇIK" or "KAPALI")
    btn.TextColor3 = Color3.fromRGB(220,220,220)
    btn.Font = Enum.Font.SourceSansBold
    btn.TextSize = 17
    btn.AutoButtonColor = false

    btn.MouseButton1Click:Connect(function()
        settings[setting] = not settings[setting]
        btn.BackgroundColor3 = settings[setting] and Color3.fromRGB(39,81,44) or Color3.fromRGB(40,40,45)
        btn.Text = text..": "..(settings[setting] and "AÇIK" or "KAPALI")
    end)
end

-- Slider
local function addSlider(lblText, ypos, setKey, min, max, step)
	local label = Instance.new("TextLabel")
	label.Parent = frame
	label.Size = UDim2.new(0,165,0,17)
	label.Position = UDim2.new(0,19,0,ypos)
	label.Text = lblText..": "..tostring(settings[setKey])
	label.BackgroundTransparency = 1
	label.TextColor3 = Color3.fromRGB(180,180,180)
	label.Font = Enum.Font.SourceSans
	label.TextSize = 15

	local bar = Instance.new("Frame")
	bar.Parent = frame
	bar.Position = UDim2.new(0,19,0,ypos+18)
	bar.Size = UDim2.new(0,165,0,11)
	bar.BackgroundColor3 = Color3.fromRGB(60,60,63)
	bar.BorderSizePixel = 0
	local fill = Instance.new("Frame")
	fill.Parent = bar
	fill.Size = UDim2.new((settings[setKey]-min)/(max-min),0,1,0)
	fill.BackgroundColor3 = Color3.fromRGB(70,195,100)
	fill.BorderSizePixel = 0

	local dragging = false
	bar.InputBegan:Connect(function(io)
		if io.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
		end
	end)
	bar.InputEnded:Connect(function(io)
		if io.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = false
		end
	end)
	bar.MouseMoved:Connect(function(x)
		if dragging then
			local rel = math.clamp((x - bar.AbsolutePosition.X)/bar.AbsoluteSize.X, 0, 1)
			local val = min + (max-min)*rel
			val = math.floor(val/step+0.5)*step
			settings[setKey] = val
			fill.Size = UDim2.new((settings[setKey]-min)/(max-min),0,1,0)
			label.Text = lblText..": "..tostring(val)
		end
	end)
	bar.MouseLeave:Connect(function() dragging = false end)
end

