function toggleButton(lbl, y, key)
    local btn = Instance.new("TextButton", frame)
    btn.Size = UDim2.new(0, 220, 0, 32)
    btn.Position = UDim2.new(0,15,0,y)
    btn.BackgroundColor3 = Color3.fromRGB(44,44,44)
    btn.BorderSizePixel = 0
    btn.TextColor3 = settings[key] and Color3.fromRGB(60,220,80) or Color3.fromRGB(230,230,230)
    btn.Font = Enum.Font.SourceSansBold
    btn.TextSize = 19
    btn.Text = lbl .. ": " .. (settings[key] and "AÇIK" or "KAPALI")
    btn.AutoButtonColor = false
    btn.MouseButton1Click:Connect(function()
        settings[key] = not settings[key]
        btn.Text = lbl .. ": " .. (settings[key] and "AÇIK" or "KAPALI")
        btn.TextColor3 = settings[key] and Color3.fromRGB(60,220,80) or Color3.fromRGB(230,230,230)
    end)
end

function CreateSlider(label, y, key, min, max, inc)
    local lbl = Instance.new("TextLabel", frame)
    lbl.Size = UDim2.new(0, 180, 0, 21)
    lbl.Position = UDim2.new(0, 15, 0, y)
    lbl.BackgroundTransparency = 1
    lbl.TextColor3 = Color3.fromRGB(170,170,170)
    lbl.Font = Enum.Font.SourceSans
    lbl.TextSize = 15
    lbl.Text = label..": "..tostring(settings[key])

    local slider = Instance.new("TextButton", frame)
    slider.Size = UDim2.new(0, 180, 0, 16)
    slider.Position = UDim2.new(0, 15, 0, y+22)
    slider.BackgroundColor3 = Color3.fromRGB(77, 77, 77)
    slider.Text = ""
    slider.AutoButtonColor = false

    local bar = Instance.new("Frame", slider)
    bar.BackgroundColor3 = Color3.fromRGB(70,200,80)
    bar.Size = UDim2.new((settings[key]-min)/(max-min), 1, 0, 16)
    bar.Position = UDim2.new(0,0,0,0)
    bar.BorderSizePixel = 0

    local dragging = false
    local function update(x)
        local rel = math.clamp((x - slider.AbsolutePosition.X)/slider.AbsoluteSize.X,0,1)
        local val = math.floor((min + (max-min)*rel)/inc+0.5)*inc
        if val > max then val = max end
        if val < min then val = min end
        settings[key] = val
        bar.Size = UDim2.new((val-min)/(max-min), 1, 0, 16)
        lbl.Text = label..": "..tostring(val)
    end
    slider.InputBegan:Connect(function(io)
        if io.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
        end
    end)
    slider.InputEnded:Connect(function(io)
        if io.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    slider.MouseMoved:Connect(function(x)
        if dragging then
            update(x)
        end
    end)
    -- Extra güvenlik: out of bounds engeli
    slider.MouseLeave:Connect(function() dragging = false end)
end

