local function createOption(name, def, y, desc)
    local btn = Instance.new("TextButton")
    btn.Parent = menuFrame
    btn.Position = UDim2.new(0,21,0, y)
    btn.Size = UDim2.new(0, menuWidth-42, 0, 46)
    btn.BackgroundColor3 = cheats[name] and Color3.fromRGB(40,40,40) or Color3.fromRGB(10,10,10)
    btn.BorderSizePixel = 0
    btn.Text = ""
    local lbl = Instance.new("TextLabel", btn)
    lbl.Size = UDim2.new(1,0,1,0)
    lbl.Position = UDim2.new(0,0,0,0)
    lbl.BackgroundTransparency = 1
    lbl.TextColor3 = Color3.fromRGB(255,255,255)
    lbl.Font = Enum.Font.SourceSansBold
    lbl.TextSize = 22
    lbl.Text = name
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.TextStrokeTransparency = 0.7

    local descL = Instance.new("TextLabel", btn)
    descL.Size = UDim2.new(1,0,0,19)
    descL.Position = UDim2.new(0,0,1,-19)
    descL.BackgroundTransparency = 1
    descL.TextColor3 = Color3.fromRGB(200,200,200)
    descL.Font = Enum.Font.SourceSans
    descL.TextSize = 14
    descL.Text = desc
    descL.TextXAlignment = Enum.TextXAlignment.Left

    btn.MouseButton1Click:Connect(function()
        cheats[name] = not cheats[name]
        btn.BackgroundColor3 = cheats[name] and Color3.fromRGB(40,40,40) or Color3.fromRGB(10,10,10)
        if name == "ESP" then updateESP() end
    end)
end

