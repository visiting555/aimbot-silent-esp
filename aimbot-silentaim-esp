--------------------- ANTICHEAT BYPASS BAŞLANGIÇ ---------------------
local isBypassed = false
local old_mt = {}
local function BypassAnticheat()
    if isBypassed then return end
    isBypassed = true
    local mt = getrawmetatable(game)
    setreadonly(mt, false)
    old_mt.__index = mt.__index
    old_mt.__newindex = mt.__newindex
    old_mt.__namecall = mt.__namecall

    mt.__index = newcclosure(function(self, k)
        if type(k)=="string" then
            local l = k:lower()
            if l:find("detec") or l:find("cheat") or l:find("hacker") or l:find("ban") or l:find("log") or l:find("bypass") then
                return nil
            end
        end
        return old_mt.__index(self, k)
    end)
    mt.__newindex = newcclosure(function(self, k, v)
        if type(k)=="string" then
            local l = k:lower()
            if l:find("ban") or l:find("log") or l:find("kick") or l:find("detec") then 
                return 
            end
        end
        return old_mt.__newindex(self, k, v)
    end)
    mt.__namecall = newcclosure(function(self, ...)
        local m = getnamecallmethod and getnamecallmethod()
        if type(m)=="string" and (m:lower():find("kick") or m:lower():find("ban") or m:lower():find("cheat") or m:lower():find("detec")) then
            return nil
        end
        return old_mt.__namecall(self, ...)
    end)
    if getrenv and getgc and setfenv then
        for _,v in ipairs(getgc(true)) do
            if typeof(v)=="function" and islclosure(v) then
                local env = getfenv(v)
                if env and env.script then
                    setfenv(v, setmetatable({script={}}, {__index=function() return nil end}))
                end
            end
        end
    end

    setreadonly(mt, true)
end
