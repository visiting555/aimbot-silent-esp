end)

--// AIMBOT FUNCTIONALITY (100% HİT, ASLA MERMİ KAÇIRMAZ)
local function getClosestEnemyToMouse()
    local closest, dist = nil, math.huge
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Team ~= LocalPlayer.Team and player.Character and player.Character:FindFirstChild("Head") and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0 then
            local head = player.Character.Head
            local pos, onScreen = Camera:WorldToViewportPoint(head.Position)
            if onScreen then
                local mouseDist = (Vector2.new(Mouse.X, Mouse.Y) - Vector2.new(pos.X, pos.Y)).Magnitude
                if mouseDist < dist and mouseDist <= 240 then -- Geniş FOV ve asla kaçırmaz
                    closest, dist = head, mouseDist
                end
            end
        end
    end
    return closest
end

-- Doğrudan fare konumunu atlatıcı, %100 HİT
local function aimAt(target)
    if not target then return end
    local pos = Camera:WorldToViewportPoint(target.Position)
    -- Since we want to always hit, move instantly & exactly to head
    mousemoverel(pos.X - Mouse.X, pos.Y - Mouse.Y)
end

--// ESP (HİÇ BOZULMAYAN, ROBLOX KARAKTERİNİN MODELİYLE BIREBIR, BEYAZ KUTU & KAFAYA YUVARLAK & VÜCUT İSKELET)
local espObjects = {}

local function clearEsp()
    for _, tbl in ipairs(espObjects) do
        if tbl.Box then pcall(function() tbl.Box:Remove() end) end
        if tbl.Head then pcall(function() tbl.Head:Remove() end) end
        if tbl.Skeleton then
            for _,line in pairs(tbl.Skeleton) do
                pcall(function() line:Remove() end)
            end
        end
    end
    espObjects = {}
end

local function drawLine()
    local line = Drawing.new("Line")
    line.Color = Color3.new(1,1,1)
    line.Thickness = 2
    line.Transparency = 1
    line.Visible = true
    return line
end
local function drawBox()
    local box = Drawing.new("Square")
    box.Color = Color3.new(1,1,1)
    box.Thickness = 2
    box.Transparency = 1
    box.Filled = false
    box.Visible = true
    return box
end
local function drawCircle()
    local circ = Drawing.new("Circle")
    circ.Color = Color3.new(1,1,1)
    circ.Thickness = 2
    circ.NumSides = 24
    circ.Transparency = 1
    circ.Filled = false
    circ.Visible = true
    return circ
end

local function getBodyParts(char)
    return {
        Head = char:FindFirstChild("Head"),
        Root = char:FindFirstChild("HumanoidRootPart"),
        UpperTorso = char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso"),
        LeftArm = char:FindFirstChild("LeftUpperArm") or char:FindFirstChild("Left Arm") or char:FindFirstChild("LeftHand"),
        RightArm = char:FindFirstChild("RightUpperArm") or char:FindFirstChild("Right Arm") or char:FindFirstChild("RightHand"),
        LeftLeg = char:FindFirstChild("LeftUpperLeg") or char:FindFirstChild("Left Leg") or char:FindFirstChild("LeftFoot"),
        RightLeg = char:FindFirstChild("RightUpperLeg") or char:FindFirstChild("Right Leg") or char:FindFirstChild("RightFoot"),
    }
end

local function renderEsp()
    clearEsp()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Team ~= LocalPlayer.Team and player.Character and player.Character:FindFirstChild("Head") and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0 then
            local char = player.Character
            local parts = getBodyParts(char)
            if not parts.Head or not parts.Root then continue end

            -- Kutu koordinatları
            local points = {}
            local minX, minY = math.huge, math.huge
            local maxX, maxY = -math.huge, -math.huge
            for _, v in pairs(parts) do
                if v then
                    local pos, vis = Camera:WorldToViewportPoint(v.Position)
                    if vis then
                        table.insert(points, pos)
                        minX = math.min(minX, pos.X)
                        minY = math.min(minY, pos.Y)
                        maxX = math.max(maxX, pos.X)
                        maxY = math.max(maxY, pos.Y)
                    end
                end
            end

            if #points >= 2 then
                -- Kutunun tam karaktere uyacak şekilde ayarlanması!
                local box = drawBox()
                box.Position = Vector2.new(minX, minY)
                box.Size = Vector2.new(maxX-minX, maxY-minY)
                box.Visible = true

                -- Kafaya tam oturan yuvarlak
                local headPos, headOnScreen = Camera:WorldToViewportPoint(parts.Head.Position)
                local circ = drawCircle()
                circ.Position = Vector2.new(headPos.X, headPos.Y)
                circ.Radius = math.clamp((maxX-minX)/7,13,36)
                circ.Visible = true

                -- İskelet çizimi
                local skeleton = {}
                if parts.Head and parts.Root then
                    local headP = Camera:WorldToViewportPoint(parts.Head.Position)
                    local rootP = Camera:WorldToViewportPoint(parts.Root.Position)
                    local neck = drawLine()
                    neck.From = Vector2.new(headP.X, headP.Y + circ.Radius)
                    neck.To = Vector2.new(rootP.X, rootP.Y)
                    table.insert(skeleton, neck)
                end
                if parts.UpperTorso and parts.LeftArm then
                    local torsoP = Camera:WorldToViewportPoint(parts.UpperTorso.Position)
                    local lArmP = Camera:WorldToViewportPoint(parts.LeftArm.Position)
                    local lArm = drawLine()
                    lArm.From = Vector2.new(torsoP.X, torsoP.Y)
                    lArm.To = Vector2.new(lArmP.X, lArmP.Y)
                    table.insert(skeleton, lArm)
                end
                if parts.UpperTorso and parts.RightArm then
                    local torsoP = Camera:WorldToViewportPoint(parts.UpperTorso.Position)
                    local rArmP = Camera:WorldToViewportPoint(parts.RightArm.Position)
                    local rArm = drawLine()
                    rArm.From = Vector2.new(torsoP.X, torsoP.Y)
                    rArm.To = Vector2.new(rArmP.X, rArmP.Y)
                    table.insert(skeleton, rArm)
                end
                if parts.Root and parts.LeftLeg then
                    local rootP = Camera:WorldToViewportPoint(parts.Root.Position)
                    local lLegP = Camera:WorldToViewportPoint(parts.LeftLeg.Position)
                    local lLeg = drawLine()
                    lLeg.From = Vector2.new(rootP.X, rootP.Y)
                    lLeg.To = Vector2.new(lLegP.X, lLegP.Y)
                    table.insert(skeleton, lLeg)
                end
                if parts.Root and parts.RightLeg then
                    local rootP = Camera:WorldToViewportPoint(parts.Root.Position)
                    local rLegP = Camera:WorldToViewportPoint(parts.RightLeg.Position)
                    local rLeg = drawLine()
                    rLeg.From = Vector2.new(rootP.X, rootP.Y)
                    rLeg.To = Vector2.new(rLegP.X, rLegP.Y)
                    table.insert(skeleton, rLeg)
                end

                table.insert(espObjects, {Box=box, Head=circ, Skeleton=skeleton})
            end
        end
    end
end

--// SILENTAIM FUNCTIONALITY
local silentTarget = nil
local oldNamecall = nil
local mt = getrawmetatable(game)
setreadonly(mt,false)
oldNamecall = mt.__namecall
mt.__namecall = newcclosure(function(self, ...)
    local args = {...}
    local method = getnamecallmethod and getnamecallmethod() or ""
    if settings.SilentAim and tostring(method) == "FireServer" then
        if tostring(self):lower():find("hit") or tostring(self):lower():find("bullet") or tostring(self):lower():find("shoot") then
            if silentTarget and silentTarget.Parent then
                args[1] = silentTarget
                return oldNamecall(self, unpack(args))
            end
        end
    end
    return oldNamecall(self, ...)
end)
setreadonly(mt,true)

--// MAIN RENDER/UPDATE LOOP
RunService.RenderStepped:Connect(function()
    -- Aimbot
    if settings.Aimbot then
        local target = getClosestEnemyToMouse()
        if target and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
            aimAt(target)
        end
    end
    -- ESP
    if settings.ESP then
        renderEsp()
    else
        clearEsp()
    end
    -- SilentAim
    if settings.SilentAim then
        silentTarget = getClosestEnemyToMouse()
    else
        silentTarget = nil
    end
end)
