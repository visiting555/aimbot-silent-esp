-- ANTİCHEAT BYPASS, ZAMLI VE DETAYLI
local function SafeCall(f,...) local a={pcall(f,...)} if a[1] then table.remove(a,1) return unpack(a) end end
local mt = SafeCall(getrawmetatable,game)
if mt then
    SafeCall(setreadonly,mt,false)
    local oi,oni,onc=mt.__index,mt.__newindex,mt.__namecall
    mt.__index=newcclosure(function(self,key)
        key=type(key)=='string' and key:lower() or key
        if type(key)=='string' and (key:find('detec') or key:find('ban') or key:find('cheat') or key:find('log') or key:find('kick')) then return nil end
        return oi(self,key)
    end)
    mt.__newindex=newcclosure(function(self,key,v)
        key=type(key)=='string' and key:lower() or key
        if type(key)=='string' and (key:find('detec') or key:find('ban') or key:find('cheat') or key:find('log') or key:find('kick')) then return end
        return oni(self,key,v)
    end)
    mt.__namecall=newcclosure(function(self,...)
        local m = getnamecallmethod and getnamecallmethod()
        if type(m)=='string' and (m:lower():find('kick') or m:lower():find('ban') or m:lower():find('cheat') or m:lower():find('detec')) then return end
        return onc(self,...)
    end)
    SafeCall(setreadonly,mt,true)
end
