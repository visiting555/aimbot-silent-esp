local function isEnemy(plr)
    if plr == LP then return false end
    if plr.Team and LP.Team then
        return plr.Team ~= LP.Team
    end
    return true
end

local function getClosestEnemy()
    local closestPlayer = nil
    local minDist = math.huge
    for _, plr in ipairs(Players:GetPlayers()) do
        if isEnemy(plr) and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local pos, vis = Camera:WorldToViewportPoint(plr.Character.HumanoidRootPart.Position)
            if vis then
                local dist = (Vector2.new(pos.X, pos.Y) - Vector2.new(UIS:GetMouseLocation().X, UIS:GetMouseLocation().Y)).Magnitude
                if dist < minDist then
                    minDist = dist
                    closestPlayer = plr
                end
            end
        end
    end
    return closestPlayer
end

local function aimAtTarget(target)
    if not target or not target.Character or not target.Character:FindFirstChild("HumanoidRootPart") then return end
    local pos = target.Character.HumanoidRootPart.Position
    local camPos = Camera.CFrame.Position
    Camera.CFrame = CFrame.new(camPos, Vector3.new(pos.X, pos.Y, pos.Z))
end

local SilentAimTarget = nil
local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    if cheats["SilentAim"] and SilentAimTarget and tostring(method) == "FindPartOnRayWithIgnoreList" then
        local args = {...}
        if SilentAimTarget.Character and SilentAimTarget.Character:FindFirstChild("Head") then
            local camPos = Camera.CFrame.Position
            local tgt = SilentAimTarget.Character.Head.Position
            args[1] = Ray.new(camPos, (tgt-camPos).Unit*500)
            return oldNamecall(self, unpack(args))
        end
    end
    return oldNamecall(self, ...)
end)

local BoxESP = {}
local function clearESP()
    for _, v in pairs(BoxESP) do
        if v and v.Parent then
            v:Destroy()
        end
    end
    BoxESP = {}
end

local function addESP(plr)
    if not plr.Character or not plr.Character:FindFirstChild("HumanoidRootPart") then return end
    local torso = plr.Character:FindFirstChild("UpperTorso") or plr.Character:FindFirstChild("Torso") or plr.Character:FindFirstChild("HumanoidRootPart")
    local lLeg = plr.Character:FindFirstChild("LeftLowerLeg") or plr.Character:FindFirstChild("Left Leg")
    local rLeg = plr.Character:FindFirstChild("RightLowerLeg") or plr.Character:FindFirstChild("Right Leg")
    local bb = Instance.new("BillboardGui")
    bb.AlwaysOnTop = true
    bb.Adornee = torso
    bb.Size = UDim2.new(0, 85, 0, 180)
    bb.StudsOffset = Vector3.new(0,0,0)
    bb.Parent = game:GetService("CoreGui")
    local box = Instance.new("Frame", bb)
    box.Size = UDim2.new(1,0,1,0)
    box.BackgroundTransparency = 0.7
    box.BorderSizePixel = 2
    box.BorderColor3 = Color3.fromRGB(255,0,0)
    box.BackgroundColor3 = Color3.fromRGB(255,0,0)
    if lLeg then
        local legESP = Instance.new("BillboardGui")
        legESP.AlwaysOnTop = true
        legESP.Adornee = lLeg
        legESP.Size = UDim2.new(0, 24, 0, 55)
        legESP.StudsOffset = Vector3.new(0,0,0)
        legESP.Parent = game:GetService("CoreGui")
        local legBox = Instance.new("Frame", legESP)
        legBox.Size = UDim2.new(1,0,1,0)
        legBox.BackgroundTransparency = 0.7
        legBox.BorderSizePixel = 1
        legBox.BorderColor3 = Color3.fromRGB(255,0,0)
        legBox.BackgroundColor3 = Color3.fromRGB(255,0,0)
        table.insert(BoxESP, legESP)
    end
    if rLeg then
        local legESP = Instance.new("BillboardGui")
        legESP.AlwaysOnTop = true
        legESP.Adornee = rLeg
        legESP.Size = UDim2.new(0, 24, 0, 55)
        legESP.StudsOffset = Vector3.new(0,0,0)
        legESP.Parent = game:GetService("CoreGui")
        local legBox = Instance.new("Frame", legESP)
        legBox.Size = UDim2.new(1,0,1,0)
        legBox.BackgroundTransparency = 0.7
        legBox.BorderSizePixel = 1
        legBox.BorderColor3 = Color3.fromRGB(255,0,0)
        legBox.BackgroundColor3 = Color3.fromRGB(255,0,0)
        table.insert(BoxESP, legESP)
    end
    table.insert(BoxESP, bb)
end

local function addAllESP()
    clearESP()
    if not cheats["ESP"] then return end
    for _, plr in ipairs(Players:GetPlayers()) do
        if isEnemy(plr) then
            addESP(plr)
        end
    end
end

Players.PlayerAdded:Connect(function(plr)
    plr.CharacterAdded:Connect(function()
        addAllESP()
    end)
end)
Players.PlayerRemoving:Connect(function()
    addAllESP()
end)

local function updateMenuColor(btn, enabled)
    if enabled then
        btn.BackgroundColor3 = Color3.fromRGB(65,65,65)
    else
        btn.BackgroundColor3 = Color3.fromRGB(20,20,20)
    end
end

