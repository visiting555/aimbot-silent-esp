-- ROBLOX HİLESİ - AİMBOT, ESP, SİLENTAİM, MENÜLÜ

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Camera = workspace.CurrentCamera

local LocalPlayer = Players.LocalPlayer
local Mouse = LocalPlayer:GetMouse()

local cheats = {
    Aimbot = false,
    ESP = false,
    SilentAim = false
}

local menu = {
    Visible = false,
    X = 450,
    Y = 200,
    Width = 270,
    Height = 220
}

local aimTarget = nil
local ESP_Instances = {}

function isEnemy(player)
    if player == LocalPlayer then return false end
    if player.Team ~= nil and LocalPlayer.Team ~= nil then
        return player.Team ~= LocalPlayer.Team
    end
    return true
end

function getClosestEnemyToCursor()
    local shortest = math.huge
    local target = nil
    for _, player in ipairs(Players:GetPlayers()) do
        if isEnemy(player) and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local pos, onscreen = Camera:WorldToViewportPoint(player.Character.HumanoidRootPart.Position)
            if onscreen then
                local dist = (Vector2.new(pos.X, pos.Y) - Vector2.new(Mouse.X, Mouse.Y)).magnitude
                if dist < shortest then
                    shortest = dist
                    target = player
                end
            end
        end
    end
    return target
end

function doAimbot()
    if not cheats.Aimbot then return end
    local target = getClosestEnemyToCursor()
    if not target then return end
    if target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
        local root = target.Character.HumanoidRootPart
        local camPos = Camera.CFrame.Position
        local direction = (root.Position - camPos).Unit
        Camera.CFrame = CFrame.new(camPos, camPos + direction)
    end
end

function doSilentAim()
    if not cheats.SilentAim then aimTarget = nil return end
    aimTarget = getClosestEnemyToCursor()
end

local oldNamecall = nil
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    if cheats.SilentAim and aimTarget and tostring(method) == "FindPartOnRayWithIgnoreList" then
        local args = {...}
        if aimTarget.Character and aimTarget.Character:FindFirstChild("Head") then
            local head = aimTarget.Character.Head.Position
            local camPos = Camera.CFrame.Position
            local dir = (head - camPos).Unit * 500
            args[1] = Ray.new(camPos, dir)
            return oldNamecall(self, unpack(args))
        end
    end
    return oldNamecall(self, ...)
end)

function removeESP()
    for _, v in pairs(ESP_Instances) do
        if v and v.Parent then
            v:Destroy()
        end
    end
    ESP_Instances = {}
end

function createESPForCharacter(char)
    if not char:FindFirstChild("HumanoidRootPart") then return end
    local root = char.HumanoidRootPart
    local gui = Instance.new("BillboardGui")
    gui.AlwaysOnTop = true
    gui.Size = UDim2.new(0, 80, 0, 180)
    gui.Adornee = root
    gui.Parent = game:GetService("CoreGui")
    local rect = Instance.new("Frame")
    rect.Size = UDim2.new(1,0,1,0)
    rect.BackgroundTransparency = 0.5
    rect.BackgroundColor3 = Color3.fromRGB(255,0,0)
    rect.Parent = gui
    rect.BorderColor3 = Color3.fromRGB(255,0,0)
    rect.BorderSizePixel = 2
    table.insert(ESP_Instances, gui)
end

function updateESP()
    if not cheats.ESP then
        removeESP()
        return
    end
    removeESP()
    for _, player in ipairs(Players:GetPlayers()) do
        if isEnemy(player) and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            createESPForCharacter(player.Character)
        end
    end
end

Players.PlayerAdded:Connect(function(plr)
    plr.CharacterAdded:Connect(function()
        updateESP()
    end)
end)
Players.PlayerRemoving:Connect(function()
    updateESP()
end)

local menuGui = Instance.new("ScreenGui", game:GetService("CoreGui"))
menuGui.Name = "HileMenusu"
menuGui.ResetOnSpawn = false

local bg = Instance.new("Frame", menuGui)
bg.Position = UDim2.new(0, menu.X, 0, menu.Y)
bg.Size = UDim2.new(0, menu.Width, 0, menu.Height)
bg.BackgroundColor3 = Color3.fromRGB(255,255,255)
bg.BorderColor3 = Color3.fromRGB(25,25,25)
bg.BorderSizePixel = 2
bg.Visible = false

local title = Instance.new("TextLabel", bg)
title.Text = "ROBLOX HİLE MENÜSÜ"
title.TextColor3 = Color3.fromRGB(0,0,0)
title.Size = UDim2.new(1,0,0,40)
title.Position = UDim2.new(0,0,0,0)
title.BackgroundTransparency = 1
title.Font = Enum.Font.SourceSansBold
title.TextScaled = true

local options = {"Aimbot","ESP","SilentAim"}
local buttons = {}

for i, opt in ipairs(options) do
    local btn = Instance.new("TextButton", bg)
    btn.Size = UDim2.new(1,-30,0,36)
    btn.Position = UDim2.new(0,15,0,45+(i-1)*55)
    btn.BackgroundColor3 = Color3.fromRGB(30,30,30)
    btn.BorderSizePixel = 0
    btn.Text = opt
    btn.Name = opt
    btn.TextColor3 = Color3.fromRGB(255,255,255)
    btn.Font = Enum.Font.SourceSansBold
    btn.TextSize = 21
    btn.AutoButtonColor = false
    btn.MouseButton1Click:Connect(function()
        cheats[opt] = not cheats[opt]
        btn.BackgroundColor3 = cheats[opt] and Color3.fromRGB(70,70,70) or Color3.fromRGB(30,30,30)
        if opt == "ESP" then
            updateESP()
        end
    end)
    btn.BackgroundColor3 = cheats[opt] and Color3.fromRGB(70,70,70) or Color3.fromRGB(30,30,30)
    buttons[opt] = btn
end

UserInputService.InputBegan:Connect(function(input, processed)
    if not processed and input.KeyCode == Enum.KeyCode.Insert then
        menu.Visible = not menu.Visible
        bg.Visible = menu.Visible
    end
end)

RunService.RenderStepped:Connect(function()
    if cheats.Aimbot then
        doAimbot()
    end
    if cheats.SilentAim then
        doSilentAim()
    else
        aimTarget = nil
    end
end)

updateESP()
