local optionHeight = 48
local optionPad = 14

local options = {"Aimbot", "ESP", "SilentAim"}
local optionDescs = {
    Aimbot = "Sadece düşmana kilitlenir",
    ESP = "Kırmızı çizgi vücut-bacak",
    SilentAim = "Susturulmuş otomatik nişan"
}
local currY = 38
local buttons = {}

local function updateMenuBtn(btn, enabled)
    if enabled then
        btn.BackgroundColor3 = Color3.fromRGB(40,40,40)
    else
        btn.BackgroundColor3 = Color3.fromRGB(15,15,15)
    end
end

for _, v in ipairs(options) do
    local btn = Instance.new("TextButton")
    btn.Parent = bg
    btn.Name = v.."Btn"
    btn.Size = UDim2.new(0.75,0,0,optionHeight-10)
    btn.Position = UDim2.new(0.13,0,0, currY)
    btn.BackgroundColor3 = Color3.fromRGB(15,15,15)
    btn.Text = v
    btn.Font = Enum.Font.SourceSansBold
    btn.TextSize = 22
    btn.TextColor3 = Color3.fromRGB(255,255,255)
    btn.BorderSizePixel = 0
    local desc = Instance.new("TextLabel", bg)
    desc.Size = UDim2.new(1, -45, 0, 16)
    desc.Position = UDim2.new(0.14,0,0,currY + 32)
    desc.Text = optionDescs[v]
    desc.TextColor3 = Color3.fromRGB(0,0,0)
    desc.Font = Enum.Font.SourceSans
    desc.TextSize = 16
    desc.BackgroundTransparency = 1
    desc.ZIndex = 2
    desc.TextXAlignment = Enum.TextXAlignment.Left
    btn.MouseButton1Click:Connect(function()
        cheats[v] = not cheats[v]
        updateMenuBtn(btn, cheats[v])
        if v == "ESP" then
            updateESP()
        end
    end)
    updateMenuBtn(btn, cheats[v])
    buttons[v] = btn
    currY = currY + optionHeight
end

UIS.InputBegan:Connect(function(input,gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.Insert then
        menuOpen = not menuOpen
        bg.Visible = menuOpen
    end
end)

topBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragOffset = Vector2.new(UIS:GetMouseLocation().X, UIS:GetMouseLocation().Y) - Vector2.new(bg.Position.X.Offset, bg.Position.Y.Offset)
    end
end)
topBar.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

UIS.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local mouseLoc = UIS:GetMouseLocation()
        bg.Position = UDim2.new(0, mouseLoc.X - dragOffset.X, 0, mouseLoc.Y - dragOffset.Y)
    end
end)

RS.RenderStepped:Connect(function()
    if cheats["Aimbot"] then
        local tgt = getClosestEnemy()
        if tgt then
            aimAt(tgt)
        end
    end
    if cheats["SilentAim"] then
        SilentAimTarget = getClosestEnemy()
    else
        SilentAimTarget = nil
    end
end)

updateESP()
