-- === ENEMY TESPİTİ === --
local function isEnemy(player)
    if player == LocalPlayer then return false end
    if player.Team and LocalPlayer.Team and player.Team == LocalPlayer.Team then return false end
    return true
end

-- === EN YAKIN DÜŞMAN BULMA === --
local function getClosestEnemy()
    local mouse = UIS:GetMouseLocation()
    local closest, closestDist = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if isEnemy(p) and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local pos, visible = Camera:WorldToViewportPoint(p.Character.HumanoidRootPart.Position)
            if visible then
                local dist = (Vector2.new(pos.X, pos.Y) - Vector2.new(mouse.X, mouse.Y)).Magnitude
                if dist < closestDist then
                    closestDist = dist
                    closest = p
                end
            end
        end
    end
    return closest
end

-- ========== AIMBOT ========== --
local function aimAt(target)
    if not target or not target.Character or not target.Character:FindFirstChild("HumanoidRootPart") then return end
    local tgtPos = target.Character.HumanoidRootPart.Position
    Camera.CFrame = CFrame.new(Camera.CFrame.Position, tgtPos)
end

-- ========== SILENTAIM ========== --
local SilentAimTarget = nil
local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    if not checkcaller() then
        local method = getnamecallmethod()
        if CHEATS.SilentAim and SilentAimTarget and tostring(method) == "FindPartOnRayWithIgnoreList" then
            local args = {...}
            if SilentAimTarget.Character and SilentAimTarget.Character:FindFirstChild("Head") then
                local camPos = Camera.CFrame.Position
                args[1] = Ray.new(camPos, (SilentAimTarget.Character.Head.Position-camPos).Unit*500)
                return oldNamecall(self, unpack(args))
            end
        end
    end
    return oldNamecall(self, ...)
end)

-- ========== ESP ========== --
local DRAWING = Drawing
local espObjects = {}

local function clearESP()
    for _, obj in ipairs(espObjects) do
        if obj and obj.Remove then obj:Remove() end
    end
    espObjects = {}
end

local function createEspBox(part, color)
    local box = DRAWING.new("Square")
    box.Color = color
    box.Filled = false
    box.Thickness = 2
    box.Transparency = 0.8
    box.Visible = true
    box.partRef = part
    return box
end

local function updateESP()
    clearESP()
    if not CHEATS.ESP then return end
    for _, p in ipairs(Players:GetPlayers()) do
        if isEnemy(p) and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            -- Kutu
            local hrp = p.Character.HumanoidRootPart
            local box = createEspBox(hrp, Color3.fromRGB(255,44,44))
            table.insert(espObjects, box)
        end
    end
end

local function stepESP()
    for _, box in ipairs(espObjects) do
        if box and box.partRef and box.partRef.Parent then
            local pos, visible = Camera:WorldToViewportPoint(box.partRef.Position)
            local sizeY = 90
            local sizeX = 70
            if visible then
                box.Visible = true
                box.Position = Vector2.new(pos.X-sizeX/2, pos.Y-sizeY/2)
                box.Size = Vector2.new(sizeX, sizeY)
            else
                box.Visible = false
            end
        else
            box.Visible = false
        end
    end
end

