-- Toggle fonksiyonu
local function MakeToggle(text, settingName, Y)
    local bg = Instance.new("Frame", main)
    bg.Size = UDim2.new(0, 210, 0, 30)
    bg.Position = UDim2.new(0,23,0,Y)
    bg.BorderSizePixel = 0
    bg.BackgroundColor3 = Color3.fromRGB(38,40,46)
    local uic = Instance.new("UICorner", bg) uic.CornerRadius = UDim.new(0,8)
    local btn = Instance.new("TextButton", bg)
    btn.Size = UDim2.new(1,0,1,0)
    btn.BackgroundTransparency = 1
    btn.Font = Enum.Font.GothamBold
    btn.Text = text .. ": "..(settings[settingName] and "AÇIK" or "KAPALI")
    btn.TextColor3 = settings[settingName] and Color3.fromRGB(70,235,115) or Color3.new(1,1,1)
    btn.TextSize = 16
    btn.AutoButtonColor = false 
    btn.MouseButton1Click:Connect(function()
        settings[settingName] = not settings[settingName]
        btn.Text = text .. ": "..(settings[settingName] and "AÇIK" or "KAPALI")
        btn.TextColor3 = settings[settingName] and Color3.fromRGB(70,235,115) or Color3.new(1,1,1)
    end)
end

local function MakeSlider(lbl, settingVar, Y, min, max, dec)
    local label = Instance.new("TextLabel", main)
    label.Size = UDim2.new(0,175,0,18)
    label.Position = UDim2.new(0,25,0,Y)
    label.BackgroundTransparency = 1
    label.Text = lbl..": "..tostring(settings[settingVar])
    label.Font = Enum.Font.Gotham
    label.TextColor3 = Color3.fromRGB(200,200,200)
    label.TextSize = 15
    label.TextXAlignment = Enum.TextXAlignment.Left

    local fr = Instance.new("Frame", main)
    fr.Size = UDim2.new(0,175,0,10)
    fr.Position = UDim2.new(0,25,0,Y+19)
    fr.BackgroundColor3 = Color3.fromRGB(43,44,52)
    fr.BorderSizePixel = 0
    local uic = Instance.new("UICorner", fr) uic.CornerRadius = UDim.new(1,0)
    local fill = Instance.new("Frame", fr)
    fill.Size = UDim2.new((settings[settingVar]-min)/(max-min),0,1,0)
    fill.BackgroundColor3 = Color3.fromRGB(66,212,96)
    fill.BorderSizePixel = 0
    local uic2 = Instance.new("UICorner", fill) uic2.CornerRadius = UDim.new(1,0)

    local dragging = false
    fr.InputBegan:Connect(function(input)
        if input.UserInputType==Enum.UserInputType.MouseButton1 then dragging = true end
    end)
    fr.InputEnded:Connect(function(input)
        if input.UserInputType==Enum.UserInputType.MouseButton1 then dragging = false end
    end)
    fr.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement and dragging then
            local percent = math.clamp((input.Position.X - fr.AbsolutePosition.X)/fr.AbsoluteSize.X,0,1)
            local val = min + (max-min)*percent
            if dec then
                val = math.floor(val/dec + 0.5)*dec
            else
                val = math.floor(val+0.5)
            end
            settings[settingVar] = val
            fill.Size = UDim2.new((val - min)/(max-min),0,1,0)
            label.Text = lbl..": "..tostring(val)
        end
    end)
    fr.MouseLeave:Connect(function() dragging = false end)
end

