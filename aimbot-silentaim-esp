-- ANTICHEAT BYPASS (hook metatable, __index, __newindex, __namecall, environment patchleri)
local oldMethods, isBypassed = {}, false
local function BypassAnticheat()
    if isBypassed then return end
    isBypassed = true
    -- Disable property changed signals
    local mt = getrawmetatable(game)
    setreadonly(mt, false)
    oldMethods.__newindex = mt.__newindex
    oldMethods.__index = mt.__index
    oldMethods.__namecall = mt.__namecall

    -- Patch __index 
    mt.__index = newcclosure(function(self, k)
        if tostring(k):find("Hacker") or tostring(k):find("Anti") then return nil end
        return oldMethods.__index(self, k)
    end)

    -- Patch __newindex
    mt.__newindex = newcclosure(function(self, k, v)
        if tostring(k):find("Ban") or tostring(k):find("Log") then return end
        return oldMethods.__newindex(self, k, v)
    end)

    -- Patch __namecall
    mt.__namecall = newcclosure(function(self, ...)
        local m = getnamecallmethod()
        if type(m) == "string" and (m:find("Kick") or m:find("Ban")) then return nil end
        return oldMethods.__namecall(self, ...)
    end)

    -- Environment spoof (basic)
    if getrenv then
        for _,v in pairs(getgc()) do
            if typeof(v)=="function" and islclosure(v) then
                pcall(function()
                    if getfenv(v).script then
                        setupvalue(v, 1, function(...) return true end)
                    end
                end)
            end
        end
    end

    setreadonly(mt, true)
end

BypassAnticheat()


