local cheats = {
    ["Aimbot"] = false,
    ["ESP"] = false,
    ["SilentAim"] = false
}

local menuOpen = false
local menuFrame = nil

local function isEnemy(player)
    if player == LP then return false end
    if player.Team ~= nil and LP.Team ~= nil then
        return player.Team ~= LP.Team
    end
    return true
end

local function getClosestEnemy()
    local mousePos = UIS:GetMouseLocation()
    local minDist, closest = math.huge, nil
    for _, player in ipairs(Players:GetPlayers()) do
        if isEnemy(player) and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local pos, onscreen = Camera:WorldToViewportPoint(player.Character.HumanoidRootPart.Position)
            if onscreen then
                local dist = (Vector2.new(pos.X, pos.Y) - Vector2.new(mousePos.X, mousePos.Y)).Magnitude
                if dist < minDist then
                    minDist = dist
                    closest = player
                end
            end
        end
    end
    return closest
end

local function aimAt(target)
    if not target or not target.Character or not target.Character:FindFirstChild("HumanoidRootPart") then return end
    local tPos = target.Character.HumanoidRootPart.Position
    local cPos = Camera.CFrame.Position
    Camera.CFrame = CFrame.new(cPos, Vector3.new(tPos.X, tPos.Y, tPos.Z))
end

local SilentAimTarget = nil
local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    if cheats["SilentAim"] and SilentAimTarget and tostring(method) == "FindPartOnRayWithIgnoreList" then
        local args = {...}
        if SilentAimTarget.Character and SilentAimTarget.Character:FindFirstChild("Head") then
            local camPos = Camera.CFrame.Position
            local tgt = SilentAimTarget.Character.Head.Position
            args[1] = Ray.new(camPos, (tgt-camPos).Unit*500)
            return oldNamecall(self, unpack(args))
        end
    end
    return oldNamecall(self, ...)
end)

local espBoxes = {}
local function clearESP()
    for _, v in pairs(espBoxes) do
        if v and v.Parent then v:Destroy() end
    end
    espBoxes = {}
end

local function createESPBox(part, size)
    local gui = Instance.new("BillboardGui")
    gui.Adornee = part
    gui.Size = size
    gui.AlwaysOnTop = true
    gui.Parent = game:GetService("CoreGui")
    local box = Instance.new("Frame", gui)
    box.Size = UDim2.new(1,0,1,0)
    box.BorderSizePixel = 2
    box.BorderColor3 = Color3.fromRGB(255,0,0)
    box.BackgroundColor3 = Color3.fromRGB(255,0,0)
    box.BackgroundTransparency = 0.75
    return gui
end

local function addESP(player)
    if not player.Character then return end
    if player.Character:FindFirstChild("HumanoidRootPart") then
        local hrp = player.Character.HumanoidRootPart
        local torso = player.Character:FindFirstChild("UpperTorso") or player.Character:FindFirstChild("Torso") or hrp
        local box = createESPBox(torso, UDim2.new(0,85,0,120))
        table.insert(espBoxes, box)
        local leftLeg = player.Character:FindFirstChild("LeftLowerLeg") or player.Character:FindFirstChild("Left Leg")
        local rightLeg = player.Character:FindFirstChild("RightLowerLeg") or player.Character:FindFirstChild("Right Leg")
        if leftLeg then
            local l = createESPBox(leftLeg, UDim2.new(0,24,0,55))
            table.insert(espBoxes, l)
        end
        if rightLeg then
            local r = createESPBox(rightLeg, UDim2.new(0,24,0,55))
            table.insert(espBoxes, r)
        end
    end
end

local function updateESP()
    clearESP()
    if not cheats["ESP"] then return end
    for _, player in ipairs(Players:GetPlayers()) do
        if isEnemy(player) then
            addESP(player)
        end
    end
end

Players.PlayerAdded:Connect(function(plr)
    plr.CharacterAdded:Connect(function()
        updateESP()
    end)
end)
Players.PlayerRemoving:Connect(function()
    updateESP()
end)

