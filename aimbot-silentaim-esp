local function makeToggle(name, settingName, order)
    local Toggle = Instance.new("TextButton")
    Toggle.Name = name
    Toggle.Text = name..": OFF"
    Toggle.Font = Enum.Font.GothamBold
    Toggle.TextSize = 22
    Toggle.Size = UDim2.new(0.92,0,0, optionHeight)
    Toggle.Position = UDim2.new(0.04,0,0, yOffset + (order-1)*(optionHeight+optionPadding))
    Toggle.BackgroundColor3 = Color3.new(0,0,0) -- Black button background
    Toggle.TextColor3 = Color3.new(1,1,1) -- White text
    Toggle.AutoButtonColor = false
    Toggle.BorderSizePixel = 0
    Toggle.Parent = MenuFrame

    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0,11)
    btnCorner.Parent = Toggle

    Toggle.MouseEnter:Connect(function()
        Toggle.BackgroundColor3 = Color3.fromRGB(40,40,40)
    end)
    Toggle.MouseLeave:Connect(function()
        Toggle.BackgroundColor3 = Color3.new(0,0,0)
    end)

    Toggle.MouseButton1Click:Connect(function()
        settings[settingName] = not settings[settingName]
        Toggle.Text = name..": "..(settings[settingName] and "ON" or "OFF")
        if name == "ESP" and not settings[settingName] then clearEsp() end
    end)
    Toggle.Text = name..": OFF"
    table.insert(toggleButtons, Toggle)
    return Toggle
end

