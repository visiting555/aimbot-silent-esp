local function makeToggle(text, key, i)
    local btn = Instance.new("TextButton")
    btn.Name = key.."_Btn"
    btn.Size = UDim2.new(0.92,0,0,toggleHeight)
    btn.Position = UDim2.new(0.04,0,0,togglesY+(i-1)*(toggleHeight+toggleGap))
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 21
    btn.Text = text..": OFF"
    btn.BackgroundColor3 = Color3.fromRGB(0,0,0)
    btn.TextColor3 = Color3.fromRGB(255,255,255)
    btn.AutoButtonColor = false
    btn.BorderSizePixel = 0
    btn.Parent = mainFrame

    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 13)
    btnCorner.Parent = btn

    btn.MouseEnter:Connect(function()
        btn.BackgroundColor3 = Color3.fromRGB(38,38,38)
    end)
    btn.MouseLeave:Connect(function()
        btn.BackgroundColor3 = Color3.fromRGB(0,0,0)
    end)
    btn.MouseButton1Click:Connect(function()
        settings[key] = not settings[key]
        btn.Text = text..": "..(settings[key] and "ON" or "OFF")
        if key == "ESP" and not settings.ESP then
            clearEsp()
        end
    end)
    table.insert(toggles,btn)
    return btn
end

