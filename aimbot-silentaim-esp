-------------------- GERÇEK ANTICHEAT BYPASS --------------------
local function SafeCall(fnc, ...)
    local result = {pcall(fnc, ...)}
    if result[1] then
        table.remove(result,1)
        return unpack(result)
    end
end

local succeeded, oldmeta, rawmeta = pcall(getrawmetatable, game)
if succeeded and rawmeta then
    setreadonly(rawmeta, false)
    oldmeta = {
        __index = rawmeta.__index,
        __newindex = rawmeta.__newindex,
        __namecall = rawmeta.__namecall
    }
    rawmeta.__index = newcclosure(function(self, key)
        if type(key)=="string" then
            local low=key:lower()
            if low:find("detec") or low:find("cheat") or low:find("ban") or low:find("log") or low:find("kick") then
                return nil -- Anticheat property access block
            end
        end
        return oldmeta.__index(self, key)
    end)
    rawmeta.__newindex = newcclosure(function(self, key, val)
        if type(key)=="string" then
            local low=key:lower()
            if low:find("detec") or low:find("ban") or low:find("log") or low:find("kick") then
                return
            end
        end
        return oldmeta.__newindex(self, key, val)
    end)
    rawmeta.__namecall = newcclosure(function(self, ...)
        local m = getnamecallmethod and getnamecallmethod()
        if type(m)=="string" and (m:lower():find("kick") or m:lower():find("ban") or m:lower():find("cheat") or m:lower():find("detec")) then
            return -- Call block!
        end
        return oldmeta.__namecall(self, ...)
    end)
    setreadonly(rawmeta, true)
end

