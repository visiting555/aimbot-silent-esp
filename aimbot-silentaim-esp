-------------------- ESP KISMI --------------------
local drawings={}
local function createBox(plr)
    if plr==LocalPlayer then return end
    if drawings[plr] then return end
    local box=Drawing.new("Square")
    box.Visible=false
    box.Thickness=2
    box.Color=Color3.fromRGB(59,220,128)
    box.Filled=false
    drawings[plr]=box
end
local function removeBox(plr)
    if drawings[plr] then pcall(function() drawings[plr]:Remove() end) drawings[plr]=nil end
end
local function updateESP()
    for _,plr in ipairs(Players:GetPlayers()) do
        local show = settings.ESP and plr~=LocalPlayer
        if show and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") and plr.Character:FindFirstChild("Humanoid") then
            if plr.Character.Humanoid.Health>0 then
                createBox(plr)
                local hrp=plr.Character.HumanoidRootPart
                local TL=Camera:WorldToViewportPoint(hrp.Position+Vector3.new(-1.7,2.75,0))
                local BR=Camera:WorldToViewportPoint(hrp.Position+Vector3.new(1.7,-2.9,0))
                local center=Camera:WorldToViewportPoint(hrp.Position)
                local box=drawings[plr]
                if center.Z>0 then
                    box.Size=Vector2.new(math.abs(BR.X-TL.X),math.abs(BR.Y-TL.Y))
                    box.Position=Vector2.new(TL.X,TL.Y)
                    box.Visible=true
                else
                    box.Visible=false
                end
            else removeBox(plr) end
        else removeBox(plr) end
    end
end
Players.PlayerRemoving:Connect(removeBox)

-------------------- AIMBOT KISMI --------------------
local function getClosestTarget()
    local minD=nil; local target=nil
    for _,plr in ipairs(Players:GetPlayers()) do
        if plr~=LocalPlayer and plr.Character and plr.Character:FindFirstChild(settings.HitPart) and plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid.Health>0 then
            local part=plr.Character[settings.HitPart]
            local t,onscr=Camera:WorldToViewportPoint(part.Position)
            if onscr.Z>0 then
                local dist=(Vector2.new(Mouse.X,Mouse.Y)-Vector2.new(t.X,t.Y)).Magnitude
                if not minD or dist<minD then
                    if dist<=settings.AimbotFOV then minD,target=dist,part end
                end
            end
        end
    end
    return target
end
local function doAimbot()
    if settings.Aimbot and UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
        local tgt=getClosestTarget()
        if tgt then
            local c=Camera.CFrame.Position
            local dir=(tgt.Position-c).Unit
            local newcf=CFrame.new(c,c+dir)
            Camera.CFrame=Camera.CFrame:Lerp(newcf,settings.AimbotSmooth)
        end
    end
end

-------------------- SILENTAIM KISMI --------------------
local function getSilentTarget()
    if settings.SilentAim and math.random(1,100)<=settings.SilentHitChance then
        local minD,target=nil,nil
        for _,plr in ipairs(Players:GetPlayers()) do
            if plr~=LocalPlayer and plr.Character and plr.Character:FindFirstChild(settings.HitPart) and plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid.Health>0 then
                local part=plr.Character[settings.HitPart]
                local t,onscr=Camera:WorldToViewportPoint(part.Position)
                if onscr.Z>0 then
                    local dist=(Vector2.new(Mouse.X,Mouse.Y)-Vector2.new(t.X,t.Y)).Magnitude
                    if not minD or dist<minD then
                        if dist<=settings.AimbotFOV then minD,target=dist,part end
                    end
                end
            end
        end
        return target
    end
end

do
    local ok,mt=pcall(getrawmetatable,game)
    if ok and mt then
        setreadonly(mt,false)
        local orig=mt.__namecall
        mt.__namecall = newcclosure(function(self,...)
            local mtd = getnamecallmethod and getnamecallmethod()
            local args={...}
            if settings.SilentAim and not checkcaller() then
                if (mtd=="FindPartOnRayWithIgnoreList" and typeof(args[1])=="Ray") then
                    local sil=getSilentTarget()
                    if sil then
                        local p=args[1].Origin
                        local dir=(sil.Position-p).Unit*999
                        args[1]=Ray.new(p,dir)
                        return orig(self,unpack(args))
                    end
                elseif (mtd=="Raycast" and typeof(args[1])=="Vector3" and typeof(args[2])=="Vector3") then
                    local sil=getSilentTarget()
                    if sil then
                        local p=args[1]
                        args[2]=(sil.Position-p).Unit*999
                        return orig(self,unpack(args))
                    end
                end
            end
            return orig(self,...)
        end)
        setreadonly(mt,true)
    end
end

