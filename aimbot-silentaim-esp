-- ENEMY KONTROL
local function isEnemy(p)
    if p == LocalPlayer then return false end
    if p.Team and LocalPlayer.Team then return p.Team ~= LocalPlayer.Team end
    return true
end

local function getClosestEnemy()
    local mouse = UIS:GetMouseLocation()
    local lastDist, closest = math.huge, nil
    for _, v in ipairs(Players:GetPlayers()) do
        if isEnemy(v) and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            local pos, onScreen = Camera:WorldToViewportPoint(v.Character.HumanoidRootPart.Position)
            if onScreen then
                local dist = (Vector2.new(pos.X, pos.Y) - Vector2.new(mouse.X, mouse.Y)).Magnitude
                if dist < lastDist then
                    closest = v
                    lastDist = dist
                end
            end
        end
    end
    return closest
end

-- AIMBOT
local function aimAt(target)
    if not target or not target.Character or not target.Character:FindFirstChild("HumanoidRootPart") then return end
    local goal = target.Character.HumanoidRootPart.Position
    Camera.CFrame = CFrame.new(Camera.CFrame.Position, goal)
end

-- SILENTAIM
local SilentAimTarget = nil
local OldNamecall
OldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    if not checkcaller() then
        local method = getnamecallmethod()
        if cheats["SilentAim"] and SilentAimTarget and tostring(method) == "FindPartOnRayWithIgnoreList" then
            local args = {...}
            if SilentAimTarget.Character and SilentAimTarget.Character:FindFirstChild("Head") then
                local camPos = Camera.CFrame.Position
                args[1] = Ray.new(camPos, (SilentAimTarget.Character.Head.Position-camPos).Unit*500)
                return OldNamecall(self, unpack(args))
            end
        end
    end
    return OldNamecall(self, ...)
end)

-- ESP FONKSİYONLARI
local espDraws = {}
local function clearESP()
    for _, v in pairs(espDraws) do if v and v.Remove then v:Remove() end end
    espDraws = {}
end

local function newEspBox(part, color)
    local bb = Drawing.new("Square")
    bb.Color = color
    bb.Thickness = 2
    bb.Transparency = 0.85
    bb.Filled = false
    bb.Visible = true
    bb.ZIndex = 1
    bb.partRef = part
    return bb
end

local function updateESP()
    clearESP()
    if not cheats["ESP"] then return end
    for _, p in ipairs(Players:GetPlayers()) do
        if isEnemy(p) and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local hrp = p.Character.HumanoidRootPart
            local esp = newEspBox(hrp, Color3.fromRGB(255,0,0))
            table.insert(espDraws, esp)
        end
    end
end

local function stepESP()
    for i, esp in ipairs(espDraws) do
        if esp and esp.partRef and esp.partRef.Parent then
            local part = esp.partRef
            local pos, onscreen = Camera:WorldToViewportPoint(part.Position)
            if onscreen then
                local size = 80
                esp.Position = Vector2.new(pos.X - size/2, pos.Y - size/2)
                esp.Size = Vector2.new(size, size * 1.3)
                esp.Visible = true
            else
                esp.Visible = false
            end
        else
            esp.Visible = false
        end
    end
end

