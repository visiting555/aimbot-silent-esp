-- ANA LOOP
RS.RenderStepped:Connect(function()
    if gui.Enabled and cheatState.Aimbot then
        local tgt = getClosestEnemy()
        if tgt then aimAt(tgt) end
    end
    if cheatState.SilentAim then
        SilentAimTarget = getClosestEnemy()
    else
        SilentAimTarget = nil
    end
    if gui.Enabled and cheatState.ESP then
        updateESP()
    end
end)

