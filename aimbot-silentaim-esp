-- ESP
if (not _G.__CROSS__ESP) then _G.__CROSS__ESP = {} end
function getScreen(pos)
    local p,vis = Camera:WorldToViewportPoint(pos)
    return Vector2.new(p.X,p.Y),vis
end
function ESP_Box(player)
    if player==LocalPlayer then return end
    local char = player.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    local head = char:FindFirstChild("Head")
    if not root or not head then return end
    local box = Drawing.new("Square")
    box.Color = Color3.fromRGB(0,0,0)
    box.Thickness = 2
    box.Filled=false
    box.Transparency=1
    local circle = Drawing.new("Circle")
    circle.Color = Color3.fromRGB(255,255,255)
    circle.Thickness = 2
    circle.Filled = false
    circle.Radius = 11
    circle.Transparency = 1
    local skel = {
        body = Drawing.new("Line"),
        leftLeg = Drawing.new("Line"),
        rightLeg = Drawing.new("Line"),
        leftArm = Drawing.new("Line"),
        rightArm = Drawing.new("Line"),
        spine = Drawing.new("Line")
    }
    for _,line in pairs(skel) do line.Color = Color3.fromRGB(255,255,255) line.Thickness=2 line.Transparency=1 end

    local con
    con = RunService.RenderStepped:Connect(function()
        if not ESPActive or not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
            box.Visible = false circle.Visible = false
            for _,l in pairs(skel) do l.Visible=false end
            return
        end
        local c = player.Character
        local hrp, hd = c:FindFirstChild("HumanoidRootPart"), c:FindFirstChild("Head")
        local ll, rl = c:FindFirstChild("Left Leg") or c:FindFirstChild("LeftFoot"), c:FindFirstChild("Right Leg") or c:FindFirstChild("RightFoot")
        local la, ra = c:FindFirstChild("Left Arm") or c:FindFirstChild("LeftHand"), c:FindFirstChild("Right Arm") or c:FindFirstChild("RightHand")
        local tor = c:FindFirstChild("Torso") or c:FindFirstChild("UpperTorso")
        if hrp and hd then
            local p1,ons1 = getScreen(hrp.Position + Vector3.new(0,1.5,0))
            local p2,_ = getScreen(hrp.Position - Vector3.new(0,2,0))
            box.Size = Vector2.new(38,67)
            box.Position = Vector2.new(p1.X-38/2,p1.Y-15)
            box.Visible = true

            local hsc,ons4 = getScreen(hd.Position)
            circle.Position = Vector2.new(hsc.X,hsc.Y)
            circle.Visible = true

            -- Skeleton
            local torsoSc,onsT = tor and getScreen(tor.Position)
            local llSc, _ = ll and getScreen(ll.Position)
            local rlSc, _ = rl and getScreen(rl.Position)
            local laSc, _ = la and getScreen(la.Position)
            local raSc, _ = ra and getScreen(ra.Position)

            skel.body.From = Vector2.new(hsc.X, hsc.Y+11)
            skel.body.To = torsoSc or p1
            skel.leftLeg.From = torsoSc or p1
            skel.leftLeg.To = llSc or p2
            skel.rightLeg.From = torsoSc or p1
            skel.rightLeg.To = rlSc or p2
            skel.leftArm.From = torsoSc or p1
            skel.leftArm.To = laSc or p2
            skel.rightArm.From = torsoSc or p1
            skel.rightArm.To = raSc or p2
            for _,l in pairs(skel) do l.Visible=true end
        else
            box.Visible = false circle.Visible = false
            for _,l in pairs(skel) do l.Visible=false end
        end
    end)
    return {
        remove = function()
            pcall(function() box:Remove() circle:Remove() end)
            for _,l in pairs(skel) do pcall(function() l:Remove() end) end
            if con then con:Disconnect() end
        end
    }
end
Players.PlayerAdded:Connect(function(p)
    wait(1)
    if ESPActive then
        _G.__CROSS__ESP[p] = ESP_Box(p)
    end
end)
Players.PlayerRemoving:Connect(function(p)
    if _G.__CROSS__ESP[p] then _G.__CROSS__ESP[p].remove() end
end)
RunService.RenderStepped:Connect(function()
    if ESPActive then
        for _,plr in pairs(Players:GetPlayers()) do
            if plr~=LocalPlayer and not _G.__CROSS__ESP[plr] then
                _G.__CROSS__ESP[plr]=ESP_Box(plr)
            end
        end
    end
end)

