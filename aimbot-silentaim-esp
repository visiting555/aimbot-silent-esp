if (not _G.__CROSS__ESP) then _G.__CROSS__ESP = {} end
local function getScreen(pos)
    local p,vis = Camera:WorldToViewportPoint(pos)
    return Vector2.new(p.X,p.Y),vis
end

function ESP_Box(player)
    if player == LocalPlayer then return end
    local char = player.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    local head = char:FindFirstChild("Head")
    if not root or not head then return end
    local box = Drawing.new("Square")
    box.Color = Color3.fromRGB(0,0,0)
    box.Thickness = 2
    box.Size = Vector2.new(24,54)
    box.Filled = false
    box.Transparency = 1
    local circle = Drawing.new("Circle")
    circle.Color = Color3.fromRGB(255,255,255)
    circle.Thickness = 2
    circle.Filled = false
    circle.Radius = 7
    circle.Transparency = 1
    local skel = {
        torso = Drawing.new("Line"),
        leftLeg = Drawing.new("Line"),
        rightLeg = Drawing.new("Line"),
        leftArm = Drawing.new("Line"),
        rightArm = Drawing.new("Line")
    }
    for _, line in pairs(skel) do
        line.Color = Color3.fromRGB(255,255,255) 
        line.Thickness = 2
        line.Transparency = 1
    end
    local con
    con = RunService.RenderStepped:Connect(function()
        if not ESPActive or not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
            box.Visible = false circle.Visible = false
            for _,l in pairs(skel) do l.Visible=false end
            return
        end
        local c = player.Character
        local hrp = c:FindFirstChild("HumanoidRootPart")
        local hd = c:FindFirstChild("Head")
        local ll = c:FindFirstChild("Left Leg") or c:FindFirstChild("LeftFoot")
        local rl = c:FindFirstChild("Right Leg") or c:FindFirstChild("RightFoot")
        local la = c:FindFirstChild("Left Arm") or c:FindFirstChild("LeftHand")
        local ra = c:FindFirstChild("Right Arm") or c:FindFirstChild("RightHand")
        local tor = c:FindFirstChild("Torso") or c:FindFirstChild("UpperTorso")
        if hrp and hd then
            local basePos, vis1 = getScreen(hrp.Position + Vector3.new(0,1,0))
            box.Size = Vector2.new(24,54)
            box.Position = Vector2.new(basePos.X-12, basePos.Y-20)
            box.Visible = true

            local headPos, vis2 = getScreen(hd.Position)
            circle.Position = Vector2.new(headPos.X, headPos.Y)
            circle.Visible = true

            local torsoPos = tor and select(1,getScreen(tor.Position)) or basePos
            local llPos = ll and select(1,getScreen(ll.Position)) or basePos
            local rlPos = rl and select(1,getScreen(rl.Position)) or basePos
            local laPos = la and select(1,getScreen(la.Position)) or basePos
            local raPos = ra and select(1,getScreen(ra.Position)) or basePos

            skel.torso.From = Vector2.new(headPos.X, headPos.Y + 7)
            skel.torso.To = torsoPos
            skel.leftLeg.From = torsoPos
            skel.leftLeg.To = llPos
            skel.rightLeg.From = torsoPos
            skel.rightLeg.To = rlPos
            skel.leftArm.From = torsoPos
            skel.leftArm.To = laPos
            skel.rightArm.From = torsoPos
            skel.rightArm.To = raPos
            for _,l in pairs(skel) do l.Visible=true end
        else
            box.Visible = false circle.Visible = false
            for _,l in pairs(skel) do l.Visible=false end
        end
    end)
    return {
        remove = function()
            pcall(function() box:Remove() circle:Remove() end)
            for _,l in pairs(skel) do pcall(function() l:Remove() end) end
            if con then con:Disconnect() end
        end
    }
end

Players.PlayerAdded:Connect(function(p)
    wait(1)
    if ESPActive then
        _G.__CROSS__ESP[p] = ESP_Box(p)
    end
end)
Players.PlayerRemoving:Connect(function(p)
    if _G.__CROSS__ESP[p] then _G.__CROSS__ESP[p].remove() end
    _G.__CROSS__ESP[p] = nil
end)
RunService.RenderStepped:Connect(function()
    if ESPActive then
        for _,plr in pairs(Players:GetPlayers()) do
            if plr~=LocalPlayer and not _G.__CROSS__ESP[plr] then
                _G.__CROSS__ESP[plr]=ESP_Box(plr)
            end
        end
    else
        for _,esptable in pairs(_G.__CROSS__ESP) do
            if esptable and esptable.remove then
                esptable.remove()
            end
        end
        _G.__CROSS__ESP = {}
    end
end)

