local function getScreen(pos)
    local p,vis = Camera:WorldToViewportPoint(pos)
    return Vector2.new(p.X, p.Y), vis
end

local BOX_SIZE = Vector2.new(33, 59) -- Bacon SPec, sabit
local HEAD_RADIUS = 8 -- Sabit, tam kafa hizasinda, bacon gibi

function ESP_Box(player)
    if player == LocalPlayer then return end
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") or not char:FindFirstChild("Head") then return end

    local box = Drawing.new("Square")
    box.Color = Color3.new(1,1,1)
    box.Thickness = 2
    box.Filled = false
    box.Size = BOX_SIZE
    box.Transparency = 1

    local circle = Drawing.new("Circle")
    circle.Color = Color3.new(1,1,1)
    circle.Thickness = 2
    circle.Filled = false
    circle.Transparency = 1
    circle.Radius = HEAD_RADIUS

    local skel = {
        torso = Drawing.new("Line"),
        leftLeg = Drawing.new("Line"),
        rightLeg = Drawing.new("Line"),
        leftArm = Drawing.new("Line"),
        rightArm = Drawing.new("Line")
    }
    for _, line in pairs(skel) do
        line.Color = Color3.new(1,1,1)
        line.Thickness = 2
        line.Transparency = 1
    end

    local function update()
        local c = player.Character
        if not ESPActive or not c or not c:FindFirstChild("HumanoidRootPart") or not c:FindFirstChild("Head") then
            box.Visible = false
            circle.Visible = false
            for _,l in pairs(skel) do l.Visible = false end
            return
        end

        local hrp = c:FindFirstChild("HumanoidRootPart")
        local head = c:FindFirstChild("Head")

        -- Her zaman sabit kutu ve sabit baş çemberi
        local rootPos, rootVis = getScreen(hrp.Position)
        local headPos, headVis = getScreen(head.Position)
        if rootVis and headVis then
            -- Box baş-hizalı, body-her zaman sabit boyut, bacon gibi
            box.Position = Vector2.new(rootPos.X - BOX_SIZE.X/2, rootPos.Y - 33)
            box.Size = BOX_SIZE
            box.Color = Color3.new(1,1,1)
            box.Visible = true

            -- Head circle tam kafada ve sabit küçük çapta
            circle.Position = Vector2.new(headPos.X, headPos.Y)
            circle.Radius = HEAD_RADIUS
            circle.Color = Color3.new(1,1,1)
            circle.Visible = true

            -- Skel positions
            local function sfind(n)
                return c:FindFirstChild(n)
            end
            local lh = sfind("LeftHand") or sfind("Left Arm")
            local rh = sfind("RightHand") or sfind("Right Arm")
            local ll = sfind("LeftFoot") or sfind("Left Leg")
            local rl = sfind("RightFoot") or sfind("Right Leg")
            local ut = sfind("UpperTorso") or sfind("Torso")
            local lt = sfind("LowerTorso") or ut

            -- Torso çizgisi (kafadan üst vücuda)
            if ut then
                local utPos = select(1, getScreen(ut.Position))
                skel.torso.From = Vector2.new(headPos.X, headPos.Y+HEAD_RADIUS)
                skel.torso.To = utPos
                skel.torso.Visible = true
            else
                skel.torso.Visible = false
            end

            if ut and ll then
                skel.leftLeg.From = select(1, getScreen(ut.Position))
                skel.leftLeg.To = select(1, getScreen(ll.Position))
                skel.leftLeg.Visible = true
            else
                skel.leftLeg.Visible = false
            end

            if ut and rl then
                skel.rightLeg.From = select(1, getScreen(ut.Position))
                skel.rightLeg.To = select(1, getScreen(rl.Position))
                skel.rightLeg.Visible = true
            else
                skel.rightLeg.Visible = false
            end

            if ut and lh then
                skel.leftArm.From = select(1, getScreen(ut.Position))
                skel.leftArm.To = select(1, getScreen(lh.Position))
                skel.leftArm.Visible = true
            else
                skel.leftArm.Visible = false
            end

            if ut and rh then
                skel.rightArm.From = select(1, getScreen(ut.Position))
                skel.rightArm.To = select(1, getScreen(rh.Position))
                skel.rightArm.Visible = true
            else
                skel.rightArm.Visible = false
            end
        else
            box.Visible = false
            circle.Visible = false
            for _,l in pairs(skel) do l.Visible = false end
        end
    end

    local rscon = RunService.RenderStepped:Connect(update)
    return {
        remove = function()
            pcall(function() box:Remove() circle:Remove() end)
            for _,l in pairs(skel) do pcall(function() l:Remove() end) end
            if rscon then rscon:Disconnect() end
        end
    }
end

