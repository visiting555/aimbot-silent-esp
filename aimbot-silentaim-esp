        end)
    end

    local infoLbl = Instance.new("TextLabel", menu)
    infoLbl.Size = UDim2.new(1,0,0,25)
    infoLbl.Position = UDim2.new(0,0,1,-29)
    infoLbl.BackgroundTransparency = 1
    infoLbl.TextColor3 = Color3.fromRGB(40,40,40)
    infoLbl.Font = Enum.Font.SourceSansItalic
    infoLbl.TextSize = 15
    infoLbl.Text = "Menü için: Insert tuşu"

    return menu
end

local menuFrame = createGeneMenu()

UIS.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.Insert then
        menuOpen = not menuOpen
        if menuFrame and menuFrame.Parent then
            menuFrame.Visible = menuOpen
        end
        if gui:FindFirstChild("WholeMenu") == nil then
            menuFrame = createGeneMenu()
        end
    end
end)

RS.RenderStepped:Connect(function()
    if cheats["Aimbot"] then
        local tgt = getClosestEnemy()
        if tgt then
            aimAt(tgt)
        end
    end
    if cheats["SilentAim"] then
        SilentAimTarget = getClosestEnemy()
    else
        SilentAimTarget = nil
    end
end)

updateESP()
