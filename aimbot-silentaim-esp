-- Menü aç/kapat kontrol fonksiyonu
local function setMenu(open)
    menuOpen = open
    frame.Visible = open
    if open and CHEATS.ESP then updateESP() end
    if not open then removeESP() end
end

setMenu(true)
UIS.InputBegan:Connect(function(input,gpe)
    if gpe then return end
    if input.KeyCode == MENU_KEY then
        setMenu(not frame.Visible)
    end
end)

