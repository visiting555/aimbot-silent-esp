    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 19
    btn.Name = "BTN_"..key
    btn.BorderSizePixel = 0
    local bR = Instance.new("UICorner", btn)
    bR.CornerRadius = UDim.new(0,13)
    local lbl = Instance.new("TextLabel", btn)
    lbl.Text = tip
    lbl.BackgroundTransparency = 1
    lbl.TextColor3 = Color3.fromRGB(230,229,162)
    lbl.Font = Enum.Font.Gotham
    lbl.TextSize = 13
    lbl.Size = UDim2.new(1,0,0,18)
    lbl.Position = UDim2.new(0,0,1,-18)
    btn.MouseButton1Click:Connect(function()
        CHEATS[key] = not CHEATS[key]
        btn.BackgroundColor3 = CHEATS[key] and colorOn or colorDef
        if key == "ESP" then updateESP() end
    end)
    y = y + 56
end

