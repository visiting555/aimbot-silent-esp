-- Menü toggle
function setMenuVis(v)
    menuOpen = v
    frame.Visible = v
    if not v then clearESP() end
    if cheats.ESP and v then updateESP() end
end
setMenuVis(true)
UIS.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.Insert then
        setMenuVis(not frame.Visible)
    end
end)

-- Hile döngüleri
RS.RenderStepped:Connect(function()
    if cheats["Aimbot"] and frame.Visible then
        local tgt = getClosestEnemy()
        if tgt then aimAt(tgt) end
    end
    if cheats["SilentAim"] then
        SilentAimTarget = getClosestEnemy()
    else
        SilentAimTarget = nil
    end
    if cheats.ESP and frame.Visible then stepESP() end
end)
