-- ========== DÜŞMAN ALGILAMA ===========
local function isEnemy(plr)
    if plr == LocalPlayer then return false end
    if plr.Team and LocalPlayer.Team and plr.Team == LocalPlayer.Team then return false end
    return true
end

-- ========== EN YAKIN ===============
local function getClosestEnemy()
    local mouse = UIS:GetMouseLocation()
    local closest,dist = nil,math.huge
    for _,p in ipairs(Players:GetPlayers()) do
        if isEnemy(p) and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local pos,onc = Camera:WorldToViewportPoint(p.Character.HumanoidRootPart.Position)
            if onc then
                local d = (Vector2.new(pos.X,pos.Y)-Vector2.new(mouse.X,mouse.Y)).Magnitude
                if d < dist then dist = d closest = p end
            end
        end
    end
    return closest
end

-- ========== HİLELER ==========

-- AIMBOT --
local function aimAt(target)
    if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
        Camera.CFrame = CFrame.new(Camera.CFrame.Position, target.Character.HumanoidRootPart.Position)
    end
end

-- SILENTAIM --
local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self,...)
    if not checkcaller() then
        local method = getnamecallmethod()
        if CHEATS.SilentAim and SilentAimTarget and tostring(method)=="FindPartOnRayWithIgnoreList" then
            local args = {...}
            if SilentAimTarget.Character and SilentAimTarget.Character:FindFirstChild("Head") then
                args[1] = Ray.new(Camera.CFrame.Position, (SilentAimTarget.Character.Head.Position-Camera.CFrame.Position).Unit*500)
                return oldNamecall(self, unpack(args))
            end
        end
    end
    return oldNamecall(self,...)
end)

-- ==== ESP ===
local Drawing = (Drawing or getgenv().Drawing)
local function removeESP()
    for _,d in ipairs(espObjects) do if d and d.Remove then pcall(function() d:Remove() end) end end
    espObjects = {}
end

local function drawBox3d(pos3d, siz, col)
    local pos,vis = Camera:WorldToViewportPoint(pos3d)
    if vis then
        local box = Drawing.new("Square")
        box.Size = Vector2.new(siz.X,siz.Y)
        box.Position = Vector2.new(pos.X-siz.X/2,pos.Y-siz.Y/2)
        box.Color = col
        box.Visible = true
        box.Transparency = 0.7
        box.Filled = false
        box.Thickness = 2
        table.insert(espObjects, box)
    end
end

local function updateESP()
    removeESP()
    if not CHEATS.ESP then return end
    for _,p in ipairs(Players:GetPlayers()) do
        if isEnemy(p) and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            drawBox3d(p.Character.HumanoidRootPart.Position,Vector2.new(68,100),Color3.fromRGB(255,39,39))
        end
    end
end

local function stepESP()
    for _,box in ipairs(espObjects) do
        if box.Remove and box.Visible and box.Color then
            -- sayılı kutuları update et
        end
    end
end

