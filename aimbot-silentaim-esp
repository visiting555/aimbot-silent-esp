-- ============== ANA HİLELER ===============
local function isEnemy(plr)
    if plr == LocalPlayer then return false end
    if plr.Team and LocalPlayer.Team and plr.Team == LocalPlayer.Team then return false end
    return true
end

local function getClosestEnemy()
    local mouse = UIS:GetMouseLocation()
    local closest,dist = nil,999999
    for _,p in pairs(Players:GetPlayers()) do
        if isEnemy(p) and p.Character then
            local root = p.Character:FindFirstChild("HumanoidRootPart")
            if root then
                local pos,vis = Camera:WorldToViewportPoint(root.Position)
                if vis then
                    local d = (Vector2.new(pos.X,pos.Y)-Vector2.new(mouse.X,mouse.Y)).Magnitude
                    if d < dist then dist = d closest=p end
                end
            end
        end
    end
    return closest
end

local function aimAt(tgt)
    if not tgt or not tgt.Character then return end
    local root = tgt.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end
    Camera.CFrame = CFrame.new(Camera.CFrame.Position, root.Position)
end

local oldNamecall
oldNamecall = hookmetamethod(game,"__namecall",function(self,...)
    if not checkcaller() then
        local method = getnamecallmethod()
        if cheatState.SilentAim and SilentAimTarget and tostring(method)=="FindPartOnRayWithIgnoreList" then
            local args = {...}
            local char = SilentAimTarget.Character
            if char and char:FindFirstChild("Head") then
                args[1] = Ray.new(Camera.CFrame.Position, (char.Head.Position-Camera.CFrame.Position).Unit*500)
                return oldNamecall(self, unpack(args))
            end
        end
    end
    return oldNamecall(self,...)
end)

local function clearESP()
    for _,v in ipairs(espDrawings) do
        if v and v.Remove then v:Remove() end
    end
    espDrawings = {}
end

local function createESPBox3D(pos, siz, col)
    local spos, vis = Camera:WorldToViewportPoint(pos)
    if not vis then return end
    local box = Drawing.new("Square")
    box.Size = siz
    box.Position = Vector2.new(spos.X - siz.X/2, spos.Y - siz.Y/2)
    box.Color = col
    box.Filled = false
    box.Thickness = 2
    box.Transparency = .8
    box.Visible = true
    table.insert(espDrawings, box)
end

local function updateESP()
    clearESP()
    if not cheatState.ESP then return end
    for _,p in pairs(Players:GetPlayers()) do
        if isEnemy(p) and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            createESPBox3D(p.Character.HumanoidRootPart.Position, Vector2.new(68,105), Color3.fromRGB(208,54,54))
        end
    end
end

Players.PlayerAdded:Connect(function(plr)
    plr.CharacterAdded:Connect(function()
        if cheatState.ESP then updateESP() end
    end)
end)
Players.PlayerRemoving:Connect(function() if cheatState.ESP then updateESP() end end)

