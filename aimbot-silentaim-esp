local function makeToggle(name, settingName, order)
    local Toggle = Instance.new("TextButton")
    Toggle.Name = name
    Toggle.Text = name..": OFF"
    Toggle.Font = Enum.Font.GothamMedium
    Toggle.TextSize = 21
    Toggle.Size = UDim2.new(0.93,0,0, optionHeight)
    Toggle.Position = UDim2.new(0.035,0,0, yOffset + (order-1)*(optionHeight+optionPadding))
    Toggle.BackgroundColor3 = Color3.new(0,0,0) -- Black option background
    Toggle.TextColor3 = Color3.new(1,1,1) -- White text
    Toggle.AutoButtonColor = false
    Toggle.BorderSizePixel = 0
    Toggle.Parent = MenuFrame

    -- Rounded corners for buttons
    local uicorner = Instance.new("UICorner")
    uicorner.CornerRadius = UDim.new(0,8)
    uicorner.Parent = Toggle

    Toggle.MouseEnter:Connect(function() Toggle.BackgroundColor3 = Color3.fromRGB(50,50,50) end)
    Toggle.MouseLeave:Connect(function() Toggle.BackgroundColor3 = Color3.new(0,0,0) end)

    Toggle.MouseButton1Click:Connect(function()
        settings[settingName] = not settings[settingName]
        Toggle.Text = name .. ": " .. (settings[settingName] and "ON" or "OFF")
        if name == "ESP" and not settings[settingName] then clearEsp() end
    end)
    Toggle.Text = name..": OFF"
    table.insert(toggleButtons, Toggle)
    return Toggle
end

