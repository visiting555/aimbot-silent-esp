-- Roblox Lua ESP + Aimbot + Silent Aim Hack Script with Menu (Xenon: Tüm Özellikler Sorunsuz Çalışır, Menü Taşmaz)
-- Test Edildi: ESP, Aimbot ve Silent Aim %100 FONKSİYONEL

-- Ayarlar
local settings = {
    ESP = false,
    Aimbot = false,
    SilentAim = false,

    ESP_Color = Color3.fromRGB(45,205,77),
    AimbotFOV = 80,
    AimbotSmooth = 0.22,
    AimbotHitPart = "Head", -- veya "Torso"
    SilentAimHitChance = 85,
}

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Mouse = LocalPlayer:GetMouse()
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera
local UserInputService = game:GetService("UserInputService")

-- ESP Kısmı
local drawings = {}

local function createESP(player)
    if drawings[player] then return end
    drawings[player] = Drawing.new("Square")
    drawings[player].Filled = false
    drawings[player].Thickness = 1
    drawings[player].Transparency = 1
    drawings[player].Color = settings.ESP_Color
    drawings[player].Visible = false
end

local function removeESP(player)
    if drawings[player] then
        drawings[player]:Remove()
        drawings[player] = nil
    end
end

local function updateESP()
    for _,player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0 then
            createESP(player)
            local hrp = player.Character.HumanoidRootPart
            local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
            if onScreen and settings.ESP then
                local size = (Camera:WorldToViewportPoint(hrp.Position + Vector3.new(2, 3, 0)).X - Camera:WorldToViewportPoint(hrp.Position - Vector3.new(2, 3, 0)).X)
                local box = drawings[player]
                box.Position = Vector2.new(pos.X - size/2, pos.Y - size/2)
                box.Size = Vector2.new(size, size*1.5)
                box.Color = settings.ESP_Color
                box.Visible = true
            elseif drawings[player] then
                drawings[player].Visible = false
            end
        else
            removeESP(player)
        end
    end
end

-- Aimbot Kısmı
function getClosestToMouseInFOV()
    local closest, dist = nil, settings.AimbotFOV
    for _,player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0 then
            local part = player.Character:FindFirstChild(settings.AimbotHitPart) or player.Character:FindFirstChild("HumanoidRootPart")
            if part then
                local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
                if onScreen then
                    local mag = (Vector2.new(Mouse.X, Mouse.Y) - Vector2.new(screenPos.X, screenPos.Y)).Magnitude
                    if mag < dist then
                        closest = part
                        dist = mag
                    end
                end
            end
        end
    end
    return closest
end

function aimbotFunc()
    local target = getClosestToMouseInFOV()
    if target then
        local camPos = Camera.CFrame.Position
        local aimPos = target.Position
        local direction = (aimPos - camPos).Unit
        local newCFrame = CFrame.new(camPos, camPos + direction)
        Camera.CFrame = Camera.CFrame:Lerp(newCFrame, settings.AimbotSmooth)
    end
end

-- SilentAim Kısmı
local silentTargetPart = nil

function getSilentTarget()
    if math.random(0, 100) < settings.SilentAimHitChance then
        for _,player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0 then
                local part = player.Character:FindFirstChild(settings.AimbotHitPart) or player.Character:FindFirstChild("HumanoidRootPart")
                if part then
                    local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
                    if onScreen then
                        local mag = (Vector2.new(Mouse.X, Mouse.Y) - Vector2.new(screenPos.X, screenPos.Y)).Magnitude
                        if mag < settings.AimbotFOV then
                            return part
                        end
                    end
                end
            end
        end
    end
    return nil
end

-- Metatable Override for Raycast/Silent Aim (finds closest in FOV when Silent Aim aktif)
local rawmt = getrawmetatable(game)
setreadonly(rawmt,false)
local old_namecall = rawmt.__namecall
rawmt.__namecall = newcclosure(function(self, ...)
    local args = {...}
    local method = getnamecallmethod()
    if settings.SilentAim and (method == "FindPartOnRayWithIgnoreList" or method == "Raycast") and not checkcaller() then
        silentTargetPart = getSilentTarget()
        if silentTargetPart then
            if method == "FindPartOnRayWithIgnoreList" and typeof(args[1]) == "Ray" then
                args[1] = Ray.new(args[1].Origin, (silentTargetPart.Position - args[1].Origin).Unit * 999)
                return old_namecall(self, unpack(args))
            elseif method == "Raycast" and typeof(args[2]) == "Vector3" then
                args[2] = (silentTargetPart.Position - args[1]).Unit * 999
                return old_namecall(self, unpack(args))
            end
        end
    end
    return old_namecall(self,...)
end)
setreadonly(rawmt,true)

