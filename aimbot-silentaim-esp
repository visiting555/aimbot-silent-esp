local function robustParent()
    local guiTargets = {"CoreGui","PlayerGui"}
    for _,t in ipairs(guiTargets) do
        local s,gui = pcall(function() return LocalPlayer[t] or game:GetService(t) end)
        if s and gui then return gui end
    end
    return workspace
end

pcall(function()
    for _, obj in pairs({"ONLY_MENU_WORKS_RELOAD"}) do
        local cg = game:GetService("CoreGui")
        if cg:FindFirstChild(obj) then cg[obj]:Destroy() end
        if LocalPlayer:FindFirstChild("PlayerGui") and LocalPlayer.PlayerGui:FindFirstChild(obj) then
            LocalPlayer.PlayerGui[obj]:Destroy()
        end
    end
end)

