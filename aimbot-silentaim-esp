-- ESP
local drawings = {}
local function createBox(plr)
    if drawings[plr] == nil and plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
        local box = Drawing.new("Square")
        box.Visible = false
        box.Thickness = 2
        box.Color = Color3.fromRGB(59,220,128)
        box.Filled = false
        drawings[plr] = box
    end
end

local function removeBox(plr)
    if drawings[plr] then
        drawings[plr]:Remove()
        drawings[plr]=nil
    end
end

local function updateESP()
    for _,plr in ipairs(Players:GetPlayers()) do
        local char = plr.Character
        local ok = plr ~= LocalPlayer and settings.ESP and char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Humanoid") and char.Humanoid.Health>0
        if ok then
            createBox(plr)
            local hrp = char.HumanoidRootPart
            local TL = Camera:WorldToViewportPoint(hrp.Position + Vector3.new(-1.7,2.9,0))
            local BR = Camera:WorldToViewportPoint(hrp.Position + Vector3.new(1.7,-3,0))
            local onscreen = Camera:WorldToViewportPoint(hrp.Position)
            local box = drawings[plr]
            if onscreen.Z > 0 then
                box.Size = Vector2.new(math.abs(BR.X-TL.X),math.abs(BR.Y-TL.Y))
                box.Position = Vector2.new(TL.X,TL.Y)
                box.Visible = true
                box.Color = Color3.fromRGB(59,220,128)
            else
                box.Visible = false
            end
        else
            removeBox(plr)
        end
    end
end

-- Aimbot Hedef Bulma
local function getClosestTarget()
    local minDist, target = settings.AimbotFOV
    for _,plr in ipairs(Players:GetPlayers()) do
        local char = plr.Character
        if plr~=LocalPlayer and char and char:FindFirstChild(settings.HitPart) and char:FindFirstChild("Humanoid") and char.Humanoid.Health>0 then
            local part = char[settings.HitPart]
            local pos, onScreen = Camera:WorldToViewportPoint(part.Position)
            if onScreen.Z > 0 then
                local dist = (Vector2.new(Mouse.X,Mouse.Y)-Vector2.new(pos.X,pos.Y)).Magnitude
                if dist < minDist then
                    minDist = dist
                    target = part
                end
            end
        end
    end
    return target
end

local function doAimbot()
    if settings.Aimbot and UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
        local tgt = getClosestTarget()
        if tgt then
            local camPos = Camera.CFrame.Position
            local aimPos = tgt.Position
            local dir = (aimPos-camPos).Unit
            local newcf = CFrame.new(camPos, camPos+dir)
            Camera.CFrame = Camera.CFrame:Lerp(newcf, settings.AimbotSmooth)
        end
    end
end

-- SilentAim Hedef
local function getSilentTarget()
    if settings.SilentAim and math.random(1,100)<=settings.SilentHitChance then
        local use, minDist = nil, settings.AimbotFOV
        for _,plr in ipairs(Players:GetPlayers()) do
            local char = plr.Character
            if plr~=LocalPlayer and char and char:FindFirstChild(settings.HitPart) and char:FindFirstChild("Humanoid") and char.Humanoid.Health>0 then
                local part = char[settings.HitPart]
                local pos, onScreen = Camera:WorldToViewportPoint(part.Position)
                if onScreen.Z > 0 then
                    local dist = (Vector2.new(Mouse.X,Mouse.Y)-Vector2.new(pos.X,pos.Y)).Magnitude
                    if dist<minDist then
                        minDist = dist
                        use = part
                    end
                end
            end
        end
        return use
    end
    return nil
end

-- SilentAim Patch
do
    local rawmt = getrawmetatable(game)
    setreadonly(rawmt, false)
    local old = rawmt.__namecall
    rawmt.__namecall = newcclosure(function(self,...)
        local method = getnamecallmethod and getnamecallmethod()
        local args = {...}
        if settings.SilentAim and not checkcaller() then
            if method=="FindPartOnRayWithIgnoreList" and typeof(args[1])=="Ray" then
                local tgt = getSilentTarget()
                if tgt then
                    local p = args[1].Origin
                    local dir = (tgt.Position-p).Unit*1000
                    args[1] = Ray.new(p,dir)
                    return old(self, unpack(args))
                end
            elseif method=="Raycast" and typeof(args[1])=="Vector3" and typeof(args[2])=="Vector3" then
                local tgt = getSilentTarget()
                if tgt then
                    local p = args[1]
                    args[2] = (tgt.Position - p).Unit*1000
                    return old(self, unpack(args))
                end
            end
        end
        return old(self, ...)
    end)
    setreadonly(rawmt, true)
end

