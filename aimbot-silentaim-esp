local function createMenuButton(txt, pos, cheatKey, color)
    local btn = Instance.new("TextButton")
    btn.Parent = Main
    btn.Size = UDim2.new(0, 180, 0, 36)
    btn.Position = UDim2.new(0, 25, 0, pos)
    btn.BackgroundColor3 = cheats[cheatKey] and Color3.fromRGB(103, 202, 50) or color
    btn.BorderSizePixel = 0
    btn.Text = txt
    btn.Font = Enum.Font.GothamBold
    btn.TextColor3 = Color3.fromRGB(255,255,255)
    btn.TextSize = 18
    local crn = Instance.new("UICorner", btn)
    crn.CornerRadius = UDim.new(0, 16)
    btn.MouseButton1Click:Connect(function()
        cheats[cheatKey] = not cheats[cheatKey]
        btn.BackgroundColor3 = cheats[cheatKey] and Color3.fromRGB(103, 202, 50) or color
        if cheatKey == "ESP" then updateESP() end
    end)
    return btn
end

