    btn.TextColor3 = Color3.new(1,1,1)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 17
    btn.BorderSizePixel = 0
    btn.Text = name .. " [" .. (getfn() and "AÇIK" or "KAPALI") .. "]"
    btn.AutoButtonColor = true
    btn.TextXAlignment = Enum.TextXAlignment.Left
    ButtonY = ButtonY + 1
    btn.MouseButton1Click:Connect(function()
        setfn(not getfn())
        btn.Text = name .. " [" .. (getfn() and "AÇIK" or "KAPALI") .. "]"
    end)
    return btn
end

local function MenuSlider(name, getfn, setfn, min, max)
    local lb = Instance.new("TextLabel")
    lb.Parent = MainFrame
    lb.BackgroundTransparency = 1
    lb.Size = UDim2.new(0,110,0,28)
    lb.Position = UDim2.new(0, 22, 0, 40+(ButtonY*29))
    lb.Text = name..": "..tostring(getfn())
    lb.TextColor3 = Color3.new(0,0,0)
    lb.Font = Enum.Font.GothamBold
    lb.TextSize = 17
    lb.TextXAlignment = Enum.TextXAlignment.Left
    lb.BorderSizePixel = 0

    local box = Instance.new("TextBox")
    box.Parent = MainFrame
    box.Size = UDim2.new(0, 52, 0, 24)
    box.Position = UDim2.new(0, 156, 0, 42+(ButtonY*29))
    box.Text = tostring(getfn())
    box.Font = Enum.Font.GothamBold
    box.TextSize = 16
    box.TextColor3 = Color3.new(1,1,1)
    box.BackgroundColor3 = Color3.new(0,0,0)
    box.BorderSizePixel = 0
    box.ClearTextOnFocus = true
    box.TextXAlignment = Enum.TextXAlignment.Center

    box.FocusLost:Connect(function()
        local v = tonumber(box.Text)
        if v and v >= min and v <= max then
            setfn(v)
            lb.Text = name..": "..v
        else
            box.Text = tostring(getfn())
        end
    end)
    ButtonY = ButtonY + 1
end

