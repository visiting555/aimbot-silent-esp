local espObjects = {}
function clearEsp()
    for _, obj in ipairs(espObjects) do
        if obj.Box then pcall(function() obj.Box:Remove() end) end
        if obj.Head then pcall(function() obj.Head:Remove() end) end
        if obj.Skeleton then for _,l in ipairs(obj.Skeleton) do pcall(function() l:Remove() end) end end
    end
    espObjects = {}
end

local function DLine()
    local l = Drawing.new("Line"); l.Color=Color3.new(1,1,1); l.Thickness=2; l.Transparency=1; l.Visible=true; return l
end
local function DBox()
    local b = Drawing.new("Square"); b.Color=Color3.new(1,1,1); b.Thickness=2; b.Transparency=1; b.Filled=false; b.Visible=true; return b
end
local function DCircle()
    local c = Drawing.new("Circle"); c.Color=Color3.new(1,1,1); c.Thickness=2; c.NumSides=22; c.Transparency=1; c.Filled=false; c.Visible=true; return c
end

local function parttbl(char)
    return {
        Head = char:FindFirstChild("Head"),
        Root = char:FindFirstChild("HumanoidRootPart"),
        UpperTorso = char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso"),
        LeftArm = char:FindFirstChild("LeftUpperArm") or char:FindFirstChild("Left Arm") or char:FindFirstChild("LeftHand"),
        RightArm = char:FindFirstChild("RightUpperArm") or char:FindFirstChild("Right Arm") or char:FindFirstChild("RightHand"),
        LeftLeg = char:FindFirstChild("LeftUpperLeg") or char:FindFirstChild("Left Leg") or char:FindFirstChild("LeftFoot"),
        RightLeg = char:FindFirstChild("RightUpperLeg") or char:FindFirstChild("Right Leg") or char:FindFirstChild("RightFoot"),
    }
end

local function renderEsp()
    clearEsp()
    for _,plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Team ~= LocalPlayer.Team and plr.Character and plr.Character:FindFirstChild("Head") and plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid.Health > 0 then
            local char = plr.Character
            local pts = parttbl(char)
            if not pts.Head or not pts.Root then continue end
            local minX,minY,maxX,maxY = math.huge,math.huge,-math.huge,-math.huge
            local vecs = {}
            for _,v in pairs(pts) do
                if v then
                    local pos,onScreen = Camera:WorldToViewportPoint(v.Position)
                    if onScreen then
                        table.insert(vecs,pos)
                        minX,minY = math.min(minX,pos.X),math.min(minY,pos.Y)
                        maxX,maxY = math.max(maxX,pos.X),math.max(maxY,pos.Y)
                    end
                end
            end
            if #vecs>=2 then
                local box = DBox()
                box.Position=Vector2.new(minX,minY)
                box.Size=Vector2.new(maxX-minX,maxY-minY)
                box.Visible = true

                local hPos,_ = Camera:WorldToViewportPoint(pts.Head.Position)
                local circ = DCircle()
                circ.Position = Vector2.new(hPos.X,hPos.Y)
                circ.Radius = math.clamp((maxX-minX)/7,13,38)
                circ.Visible = true

                local skel = {}
                if pts.Head and pts.Root then
                    local head2d = Camera:WorldToViewportPoint(pts.Head.Position)
                    local root2d = Camera:WorldToViewportPoint(pts.Root.Position)
                    local n = DLine()
                    n.From = Vector2.new(head2d.X, head2d.Y + circ.Radius)
                    n.To = Vector2.new(root2d.X, root2d.Y)
                    table.insert(skel,n)
                end
                if pts.UpperTorso and pts.LeftArm then
                    local uc2d = Camera:WorldToViewportPoint(pts.UpperTorso.Position)
                    local la2d = Camera:WorldToViewportPoint(pts.LeftArm.Position)
                    local l = DLine()
                    l.From = Vector2.new(uc2d.X, uc2d.Y)
                    l.To = Vector2.new(la2d.X, la2d.Y)
                    table.insert(skel,l)
                end
                if pts.UpperTorso and pts.RightArm then
                    local uc2d = Camera:WorldToViewportPoint(pts.UpperTorso.Position)
                    local ra2d = Camera:WorldToViewportPoint(pts.RightArm.Position)
                    local r = DLine()
                    r.From = Vector2.new(uc2d.X, uc2d.Y)
                    r.To = Vector2.new(ra2d.X, ra2d.Y)
                    table.insert(skel,r)
                end
                if pts.Root and pts.LeftLeg then
                    local root2d = Camera:WorldToViewportPoint(pts.Root.Position)
                    local ll2d = Camera:WorldToViewportPoint(pts.LeftLeg.Position)
                    local l = DLine()
                    l.From = Vector2.new(root2d.X, root2d.Y)
                    l.To = Vector2.new(ll2d.X, ll2d.Y)
                    table.insert(skel,l)
                end
                if pts.Root and pts.RightLeg then
                    local root2d = Camera:WorldToViewportPoint(pts.Root.Position)
                    local rl2d = Camera:WorldToViewportPoint(pts.RightLeg.Position)
                    local r = DLine()
                    r.From = Vector2.new(root2d.X, root2d.Y)
                    r.To = Vector2.new(rl2d.X, rl2d.Y)
                    table.insert(skel,r)
                end

                table.insert(espObjects,{Box=box,Head=circ,Skeleton=skel})
            end
        end
    end
end

local function getClosestEnemyToMouse()
    local closest, minDist = nil,math.huge
    for _,plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Team ~= LocalPlayer.Team and plr.Character and plr.Character:FindFirstChild("Head") and plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid.Health > 0 then
            local head = plr.Character.Head
            local pos,onScreen = Camera:WorldToViewportPoint(head.Position)
            if onScreen then
                local dist = (Vector2.new(Mouse.X, Mouse.Y)-Vector2.new(pos.X, pos.Y)).Magnitude
                if dist < minDist and dist <= 250 then
                    closest, minDist = head, dist
                end
            end
        end
    end
    return closest
end

local function aimAt(target)
    if not target then return end
    local pos = Camera:WorldToViewportPoint(target.Position)
    mousemoverel(pos.X-Mouse.X,pos.Y-Mouse.Y)
end

local silentTarget = nil
local rawmt = getrawmetatable(game)
setreadonly(rawmt,false)
local oldnamecall = rawmt.__namecall
rawmt.__namecall = newcclosure(function(self,...)
    local args={...}
    local method = getnamecallmethod and getnamecallmethod() or ""
    if settings.SilentAim and tostring(method)=="FireServer" then
        if tostring(self):lower():find("hit") or tostring(self):lower():find("bullet") or tostring(self):lower():find("shoot") then
            if silentTarget and silentTarget.Parent then
                args[1]=silentTarget
                return oldnamecall(self, unpack(args))
            end
        end
    end
    return oldnamecall(self,...)
end)
setreadonly(rawmt,true)

RunService.RenderStepped:Connect(function()
    if settings.Aimbot then
        local tgt = getClosestEnemyToMouse()
        if tgt and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
            aimAt(tgt)
        end
    end
    if settings.ESP then
        renderEsp()
    else
        clearEsp()
    end
    if settings.SilentAim then
        silentTarget = getClosestEnemyToMouse()
    else
        silentTarget = nil
    end
end)
