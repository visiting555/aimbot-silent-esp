local drawings = {}
local function createBox(plr)
    if plr == LocalPlayer then return end
    if drawings[plr] then return end
    if not plr.Character or not plr.Character:FindFirstChild("HumanoidRootPart") then return end
    local box = Drawing.new("Square")
    box.Visible = false
    box.Thickness = 2
    box.Color = Color3.fromRGB(59,220,128)
    box.Filled = false
    drawings[plr] = box
end

local function removeBox(plr)
    if drawings[plr] then
        pcall(function() drawings[plr]:Remove() end)
        drawings[plr]=nil
    end
end

local function updateESP()
    for _,plr in ipairs(Players:GetPlayers()) do
        if plr~=LocalPlayer and settings.ESP then
            local char = plr.Character
            if char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Humanoid") and char.Humanoid.Health>0 then
                createBox(plr)
                local hrp = char.HumanoidRootPart
                local TL = Camera:WorldToViewportPoint(hrp.Position+Vector3.new(-1.7,2.75,0))
                local BR = Camera:WorldToViewportPoint(hrp.Position+Vector3.new(1.7,-2.9,0))
                local CenterScreen = Camera:WorldToViewportPoint(hrp.Position)
                local box = drawings[plr]
                if CenterScreen.Z > 0 then
                    box.Size = Vector2.new(math.abs(BR.X-TL.X), math.abs(BR.Y-TL.Y))
                    box.Position = Vector2.new(TL.X, TL.Y)
                    box.Visible = true
                else
                    box.Visible=false
                end
            else removeBox(plr) end
        else removeBox(plr) end
    end
end

Players.PlayerRemoving:Connect(removeBox)

-------------------- AIMBOT KISMI --------------------
local function getClosestTarget()
    local minDist,target = settings.AimbotFOV,nil
    for _,plr in ipairs(Players:GetPlayers()) do
        local char=plr.Character
        if plr~=LocalPlayer and char and char:FindFirstChild(settings.HitPart) and char:FindFirstChild("Humanoid") and char.Humanoid.Health>0 then
            local part = char[settings.HitPart]
            local pos,vis = Camera:WorldToViewportPoint(part.Position)
            if vis.Z>0 then
                local dist = (Vector2.new(Mouse.X, Mouse.Y) - Vector2.new(pos.X,pos.Y)).Magnitude
                if dist<minDist then minDist=dist; target=part end
            end
        end
    end
    return target
end

local function doAimbot()
    if settings.Aimbot and UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
        local tgt = getClosestTarget()
        if tgt then
            local camPos = Camera.CFrame.Position
            local dir = (tgt.Position-camPos).Unit
            local newcf = CFrame.new(camPos, camPos+dir)
            Camera.CFrame = Camera.CFrame:Lerp(newcf, settings.AimbotSmooth)
        end
    end
end

-------------------- SILENT AIM KISMI --------------------
local function getSilentTarget()
    if settings.SilentAim and math.random(1,100)<=settings.SilentHitChance then
        local minDist, target = settings.AimbotFOV, nil
        for _,plr in ipairs(Players:GetPlayers()) do
            local char=plr.Character
            if plr~=LocalPlayer and char and char:FindFirstChild(settings.HitPart) and char:FindFirstChild("Humanoid") and char.Humanoid.Health>0 then
                local part = char[settings.HitPart]
                local pos,vis = Camera:WorldToViewportPoint(part.Position)
                if vis.Z > 0 then
                    local dist = (Vector2.new(Mouse.X, Mouse.Y) - Vector2.new(pos.X, pos.Y)).Magnitude
                    if dist<minDist then minDist=dist; target=part end
                end
            end
        end
        return target
    end
    return nil
end

do
    local succeeded, mt = pcall(getrawmetatable, game)
    if succeeded and mt then
        setreadonly(mt, false)
        local orig = mt.__namecall
        mt.__namecall = newcclosure(function(self, ...)
            local method = getnamecallmethod and getnamecallmethod()
            local args = {...}
            if settings.SilentAim and not checkcaller() then
                if method=="FindPartOnRayWithIgnoreList" and typeof(args[1])=="Ray" then
                    local tgt=getSilentTarget()
                    if tgt then
                        local p=args[1].Origin
                        local dir=(tgt.Position-p).Unit*1000
                        args[1]=Ray.new(p, dir)
                        return orig(self, unpack(args))
                    end
                elseif method=="Raycast" and typeof(args[1])=="Vector3" and typeof(args[2])=="Vector3" then
                    local tgt=getSilentTarget()
                    if tgt then
                        local p=args[1]
                        args[2]=(tgt.Position-p).Unit*1000
                        return orig(self, unpack(args))
                    end
                end
            end
            return orig(self, ...)
        end)
        setreadonly(mt, true)
    end
end

