end)

--// AIMBOT (Asla kendi takımına değil, asla ıskalama yok, daima başı hedefler)
local function getClosestEnemyToMouse()
    local closest, dist = nil, math.huge
    for _,player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Team ~= LocalPlayer.Team and player.Character and player.Character:FindFirstChild("Head") and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0 then
            local head = player.Character.Head
            local screenPos, onScreen = Camera:WorldToViewportPoint(head.Position)
            if onScreen then
                local mouseDist = (Vector2.new(Mouse.X, Mouse.Y) - Vector2.new(screenPos.X, screenPos.Y)).Magnitude
                if mouseDist < dist and mouseDist <= 250 then
                    closest, dist = head, mouseDist
                end
            end
        end
    end
    return closest
end

local function aimAt(target)
    if not target then return end
    local pos = Camera:WorldToViewportPoint(target.Position)
    mousemoverel(pos.X - Mouse.X, pos.Y - Mouse.Y)
end

--// ESP (beyaz kutu, beyaz kafaya tam yuvarlak, iskelet tamam, bozulmaz!)
local espObjects = {}

function clearEsp()
    for _, obj in ipairs(espObjects) do
        if obj.Box then pcall(function() obj.Box:Remove() end) end
        if obj.Head then pcall(function() obj.Head:Remove() end) end
        if obj.Skeleton then
            for _,line in ipairs(obj.Skeleton) do
                pcall(function() line:Remove() end)
            end
        end
    end
    espObjects = {}
end

local function DLine()
    local l = Drawing.new("Line")
    l.Color = Color3.new(1,1,1)
    l.Thickness = 2
    l.Transparency = 1
    l.Visible = true
    return l
end
local function DBox()
    local b = Drawing.new("Square")
    b.Color = Color3.new(1,1,1)
    b.Thickness = 2
    b.Transparency = 1
    b.Filled = false
    b.Visible = true
    return b
end
local function DCircle()
    local c = Drawing.new("Circle")
    c.Color = Color3.new(1,1,1)
    c.Thickness = 2
    c.NumSides = 22
    c.Transparency = 1
    c.Filled = false
    c.Visible = true
    return c
end

local function getParts(chr)
    return {
        Head = chr:FindFirstChild("Head"),
        Root = chr:FindFirstChild("HumanoidRootPart"),
        UpperTorso = chr:FindFirstChild("UpperTorso") or chr:FindFirstChild("Torso"),
        LeftArm = chr:FindFirstChild("LeftUpperArm") or chr:FindFirstChild("Left Arm") or chr:FindFirstChild("LeftHand"),
        RightArm = chr:FindFirstChild("RightUpperArm") or chr:FindFirstChild("Right Arm") or chr:FindFirstChild("RightHand"),
        LeftLeg = chr:FindFirstChild("LeftUpperLeg") or chr:FindFirstChild("Left Leg") or chr:FindFirstChild("LeftFoot"),
        RightLeg = chr:FindFirstChild("RightUpperLeg") or chr:FindFirstChild("Right Leg") or chr:FindFirstChild("RightFoot"),
    }
end

local function renderEsp()
    clearEsp()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Team ~= LocalPlayer.Team and player.Character and player.Character:FindFirstChild("Head") and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0 then
            local char = player.Character
            local parts = getParts(char)
            if not parts.Head or not parts.Root then continue end

            local minX, minY = math.huge, math.huge
            local maxX, maxY = -math.huge, -math.huge
            local points = {}
            for _, v in pairs(parts) do
                if v then
                    local pos, onscr = Camera:WorldToViewportPoint(v.Position)
                    if onscr then
                        table.insert(points, pos)
                        minX, minY = math.min(minX,pos.X), math.min(minY,pos.Y)
                        maxX, maxY = math.max(maxX,pos.X), math.max(maxY,pos.Y)
                    end
                end
            end
            if #points >= 2 then
                local b = DBox()
                b.Position = Vector2.new(minX, minY)
                b.Size = Vector2.new(maxX-minX, maxY-minY)
                b.Visible = true

                local headP, _ = Camera:WorldToViewportPoint(parts.Head.Position)
                local c = DCircle()
                c.Position = Vector2.new(headP.X, headP.Y)
                c.Radius = math.clamp((maxX-minX)/7, 13, 38)
                c.Visible = true

                local skel = {}
                -- Neck
                if parts.Head and parts.Root then
                    local head2d = Camera:WorldToViewportPoint(parts.Head.Position)
                    local root2d = Camera:WorldToViewportPoint(parts.Root.Position)
                    local n = DLine()
                    n.From = Vector2.new(head2d.X, head2d.Y+c.Radius)
                    n.To = Vector2.new(root2d.X, root2d.Y)
                    table.insert(skel, n)
                end
                -- Arms
                if parts.UpperTorso and parts.LeftArm then
                    local uc2d = Camera:WorldToViewportPoint(parts.UpperTorso.Position)
                    local la2d = Camera:WorldToViewportPoint(parts.LeftArm.Position)
                    local ll = DLine()
                    ll.From = Vector2.new(uc2d.X, uc2d.Y)
                    ll.To = Vector2.new(la2d.X, la2d.Y)
                    table.insert(skel, ll)
                end
                if parts.UpperTorso and parts.RightArm then
                    local uc2d = Camera:WorldToViewportPoint(parts.UpperTorso.Position)
                    local ra2d = Camera:WorldToViewportPoint(parts.RightArm.Position)
                    local rl = DLine()
                    rl.From = Vector2.new(uc2d.X, uc2d.Y)
                    rl.To = Vector2.new(ra2d.X, ra2d.Y)
                    table.insert(skel, rl)
                end
                -- Legs
                if parts.Root and parts.LeftLeg then
                    local root2d = Camera:WorldToViewportPoint(parts.Root.Position)
                    local ll2d = Camera:WorldToViewportPoint(parts.LeftLeg.Position)
                    local legL = DLine()
                    legL.From = Vector2.new(root2d.X, root2d.Y)
                    legL.To = Vector2.new(ll2d.X, ll2d.Y)
                    table.insert(skel, legL)
                end
                if parts.Root and parts.RightLeg then
                    local root2d = Camera:WorldToViewportPoint(parts.Root.Position)
                    local rl2d = Camera:WorldToViewportPoint(parts.RightLeg.Position)
                    local legR = DLine()
                    legR.From = Vector2.new(root2d.X, root2d.Y)
                    legR.To = Vector2.new(rl2d.X, rl2d.Y)
                    table.insert(skel, legR)
                end

                table.insert(espObjects, {Box=b, Head=c, Skeleton=skel})
            end
        end
    end
end

--// SILENTAIM 
local silentTarget = nil
local oldNM = nil
local mt = getrawmetatable(game)
setreadonly(mt, false)
oldNM = mt.__namecall
mt.__namecall = newcclosure(function(self, ...)
    local args = {...}
    local method = getnamecallmethod and getnamecallmethod() or ""
    if settings.SilentAim and tostring(method) == "FireServer" then
        if tostring(self):lower():find("hit") or tostring(self):lower():find("bullet") or tostring(self):lower():find("shoot") then
            if silentTarget and silentTarget.Parent then
                args[1] = silentTarget
                return oldNM(self, unpack(args))
            end
        end
    end
    return oldNM(self, ...)
end)
setreadonly(mt, true)

--// MAIN RENDER/UPDATE
RunService.RenderStepped:Connect(function()
    -- Aimbot
    if settings.Aimbot then
        local target = getClosestEnemyToMouse()
        if target and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
            aimAt(target)
        end
    end
    -- ESP
    if settings.ESP then
        renderEsp()
    else
        clearEsp()
    end
    -- SilentAim
    if settings.SilentAim then
        silentTarget = getClosestEnemyToMouse()
    else
        silentTarget = nil
    end
end)
