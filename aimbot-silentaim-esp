local espObjects = {}
function clearEsp()
    for _, obj in ipairs(espObjects) do
        if obj.Box then pcall(function() obj.Box:Remove() end) end
        if obj.Head then pcall(function() obj.Head:Remove() end) end
        if obj.Skeleton then for _,l in ipairs(obj.Skeleton) do pcall(function() l:Remove() end) end end
    end
    espObjects = {}
end

local function DLine()
    local l = Drawing.new("Line")
    l.Color = Color3.new(1,1,1)
    l.Thickness = 2
    l.Transparency = 1
    l.Visible = true
    return l
end
local function DBox()
    local b = Drawing.new("Square")
    b.Color = Color3.new(1,1,1)
    b.Thickness = 2
    b.Transparency = 1
    b.Filled = false
    b.Visible = true
    return b
end
local function DCircle()
    local c = Drawing.new("Circle")
    c.Color = Color3.new(1,1,1)
    c.Thickness = 2
    c.NumSides = 22
    c.Transparency = 1
    c.Filled = false
    c.Visible = true
    return c
end

local function parttbl(char)
    return {
        Head = char:FindFirstChild("Head"),
        Root = char:FindFirstChild("HumanoidRootPart"),
        UpperTorso = char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso"),
        LeftArm = char:FindFirstChild("LeftUpperArm") or char:FindFirstChild("Left Arm") or char:FindFirstChild("LeftHand"),
        RightArm = char:FindFirstChild("RightUpperArm") or char:FindFirstChild("Right Arm") or char:FindFirstChild("RightHand"),
        LeftLeg = char:FindFirstChild("LeftUpperLeg") or char:FindFirstChild("Left Leg") or char:FindFirstChild("LeftFoot"),
        RightLeg = char:FindFirstChild("RightUpperLeg") or char:FindFirstChild("Right Leg") or char:FindFirstChild("RightFoot"),
    }
end

-- ESP drawing, always fresh and correct, all white, as wanted
local function renderEsp()
    clearEsp()
    for _,plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer 
        and plr.Team ~= nil and LocalPlayer.Team ~= nil
        and plr.Team ~= LocalPlayer.Team
        and plr.Character
        and plr.Character:FindFirstChild("Head")
        and plr.Character:FindFirstChild("Humanoid")
        and plr.Character.Humanoid.Health > 0 then

            local char = plr.Character
            local pts = parttbl(char)
            if not pts.Head or not pts.Root then
                continue
            end

            -- Calculate bounding box only on main bodyparts so always correct
            local mainParts = {"Head", "Root", "UpperTorso", "LeftArm", "RightArm", "LeftLeg", "RightLeg"}
            local minX, minY, maxX, maxY = math.huge, math.huge, -math.huge, -math.huge
            local positions, onScreenCount = {}, 0
            for _,partName in ipairs(mainParts) do
                local part = pts[partName]
                if part then
                    local pos, onScreen = Camera:WorldToViewportPoint(part.Position)
                    if onScreen then
                        positions[partName] = pos
                        onScreenCount = onScreenCount + 1
                        minX = math.min(minX, pos.X)
                        minY = math.min(minY, pos.Y)
                        maxX = math.max(maxX, pos.X)
                        maxY = math.max(maxY, pos.Y)
                    end
                end
            end

            if onScreenCount >= 2 then
                local box = DBox()
                box.Position = Vector2.new(minX, minY)
                box.Size = Vector2.new(math.max(14, maxX-minX), math.max(38, maxY-minY)) -- stays always same (or min bound)
                box.Visible = true

                -- Head circle
                if positions.Head then
                    local circ = DCircle()
                    circ.Position = Vector2.new(positions.Head.X, positions.Head.Y)
                    circ.Radius = math.clamp((maxX-minX)/7, 13, 38)
                    circ.Visible = true

                    -- Skeleton
                    local skeleton = {}

                    -- Head-to-root
                    if positions.Head and positions.Root then
                        local l = DLine()
                        l.From = Vector2.new(positions.Head.X, positions.Head.Y + circ.Radius)
                        l.To = Vector2.new(positions.Root.X, positions.Root.Y)
                        table.insert(skeleton, l)
                    end

                    -- UpperTorso-to-arms
                    if positions.UpperTorso and positions.LeftArm then
                        local l = DLine()
                        l.From = Vector2.new(positions.UpperTorso.X, positions.UpperTorso.Y)
                        l.To = Vector2.new(positions.LeftArm.X, positions.LeftArm.Y)
                        table.insert(skeleton, l)
                    end
                    if positions.UpperTorso and positions.RightArm then
                        local l = DLine()
                        l.From = Vector2.new(positions.UpperTorso.X, positions.UpperTorso.Y)
                        l.To = Vector2.new(positions.RightArm.X, positions.RightArm.Y)
                        table.insert(skeleton, l)
                    end

                    -- Root-to-legs
                    if positions.Root and positions.LeftLeg then
                        local l = DLine()
                        l.From = Vector2.new(positions.Root.X, positions.Root.Y)
                        l.To = Vector2.new(positions.LeftLeg.X, positions.LeftLeg.Y)
                        table.insert(skeleton, l)
                    end
                    if positions.Root and positions.RightLeg then
                        local l = DLine()
                        l.From = Vector2.new(positions.Root.X, positions.Root.Y)
                        l.To = Vector2.new(positions.RightLeg.X, positions.RightLeg.Y)
                        table.insert(skeleton, l)
                    end

                    table.insert(espObjects, {Box = box, Head = circ, Skeleton = skeleton})
                end
            end
        end
    end
end

-- Returns the closest enemy player head to mouse (not own team)
local function getClosestEnemyToMouse()
    local closest, minDist = nil, math.huge
    for _,plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer 
        and plr.Team ~= nil and LocalPlayer.Team ~= nil
        and plr.Team ~= LocalPlayer.Team
        and plr.Character and plr.Character:FindFirstChild("Head") 
        and plr.Character:FindFirstChild("Humanoid")
        and plr.Character.Humanoid.Health > 0 then
            local head = plr.Character.Head
            local screenPos, onScreen = Camera:WorldToViewportPoint(head.Position)
            if onScreen then
                local dist = (Vector2.new(Mouse.X, Mouse.Y) - Vector2.new(screenPos.X, screenPos.Y)).Magnitude
                if dist < minDist and dist <= 500 then
                    closest = head
                    minDist = dist
                end
            end
        end
    end
    return closest
end

-- Use proper input for mouse movement
local function moveMouseTo(x, y)
    -- for best compatibility
    if type(mouse_event) == "function" then
        mouse_event(1, x, y, 0, 0)
    elseif type(mousemoverel) == "function" then
        mousemoverel(x, y)
    end
end

-- Aimbot function: always dead accurate head aimbot on enemies, never teammates
local function aimAt(target)
    if not target then return end
    local pos = Camera:WorldToViewportPoint(target.Position)
    -- extra snapping for closest accuracy
    local dx, dy = pos.X - Mouse.X, pos.Y - Mouse.Y
    moveMouseTo(dx, dy)
end

local silentTarget = nil
do
    local mt = getrawmetatable(game)
    local old
    old = hookmetamethod(game, "__namecall", function(self, ...)
        local namecall = getnamecallmethod and getnamecallmethod() or ""
        local args = {...}
        if settings.SilentAim and tostring(namecall) == "FireServer" then
            local s = tostring(self):lower()
            -- hit, bullet, shoot etc.
            if (s:find("hit") or s:find("bullet") or s:find("shoot")) and silentTarget and silentTarget.Parent then
                args[1] = silentTarget
                return old(self, unpack(args))
            end
        end
        return old(self, ...)
    end)
end

RunService.RenderStepped:Connect(function()
    if settings.Aimbot then
        local target = getClosestEnemyToMouse()
        if target and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
            aimAt(target)
        end
    end

    if settings.ESP then
        renderEsp()
    else
        clearEsp()
    end

    if settings.SilentAim then
        silentTarget = getClosestEnemyToMouse()
    else
        silentTarget = nil
    end
end)
