-- ESP FONKSİYONU
local function colorRole(plr)
    -- Bazı MM2 oyunlarında Role tagı/ismi yoktur, meşhur isimlerden git
    local dn = (plr.DisplayName or plr.Name):lower()
    if dn:find("sheriff") or dn:find("polis") then
        return Color3.fromRGB(53,125,242) -- mavi
    elseif dn:find("killer") or dn:find("katil") or dn:find("murder") or dn:find("murderer") then
        return Color3.fromRGB(235,44,97) -- kirmizi
    elseif dn:find("masum") or dn:find("innocent") then
        return Color3.fromRGB(32,230,87) -- yesil
    end
    return Color3.fromRGB(224,224,224) -- default gri
end

local function addESP(plr)
    if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("Head") and not plr.Character.Head:FindFirstChild("MENU_ESP") then
        local bb = Instance.new("BillboardGui", plr.Character.Head)
        bb.Name = "MENU_ESP"
        bb.Size = UDim2.new(0,110,0,43)
        bb.Adornee = plr.Character.Head
        bb.AlwaysOnTop = true
        local roleColor = colorRole(plr)
        local lbl = Instance.new("TextLabel", bb)
        lbl.Size = UDim2.new(1,0,1,0)
        lbl.BackgroundTransparency = .46
        lbl.BackgroundColor3 = roleColor
        lbl.TextColor3 = Color3.fromRGB(255,255,255)
        lbl.TextStrokeTransparency = 0.1
        lbl.Font = Enum.Font.GothamBold
        lbl.Text = (plr.DisplayName or plr.Name)
        lbl.TextSize = 17
        lbl.BorderSizePixel = 0
    end
end
local function removeESP(plr)
    if plr.Character and plr.Character:FindFirstChild("Head") and plr.Character.Head:FindFirstChild("MENU_ESP") then
        plr.Character.Head.MENU_ESP:Destroy()
    end
end
-- Dinamik ESP aç/kapa
local function updateESP()
    for _,plr in ipairs(Players:GetPlayers()) do
        if states.esp then
            addESP(plr)
        else
            removeESP(plr)
        end
    end
end
Players.PlayerAdded:Connect(function(plr)
    plr.CharacterAdded:Connect(function()
        wait(.5)
        if states.esp then addESP(plr) end
    end)
end)
for _,plr in ipairs(Players:GetPlayers()) do
    if plr ~= LocalPlayer then
        plr.CharacterAdded:Connect(function()
            wait(.5)
            if states.esp then addESP(plr) end
        end)
    end
end

-- Aim helper
local function getClosestToCursor()
    local shortest = math.huge
    local closest = nil
    for _,plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("Head") then
            local pos,vis = Camera:WorldToViewportPoint(plr.Character.Head.Position)
            if vis then
                local dist = (Vector2.new(pos.X, pos.Y) - UserInputService:GetMouseLocation()).Magnitude
                if dist < shortest and dist < 250 then -- FOV 250 px
                    shortest = dist
                    closest = plr
                end
            end
        end
    end
    return closest
end

RunService.RenderStepped:Connect(function()
    pcall(updateESP)
    if states.aimbot then
        local target = getClosestToCursor()
        if target and target.Character and target.Character:FindFirstChild("Head") then
            local cam = workspace.CurrentCamera
            local head = target.Character.Head.Position
            cam.CFrame = CFrame.new(cam.CFrame.Position, head)
        end
    end
end)

local old; old = hookmetamethod(game, "__namecall", function(self,...)
    local args = {...}
    if states.silentaim and tostring(self)=="Hit" and getcallingscript() ~= script then
        local target = getClosestToCursor()
        if target and target.Character and target.Character:FindFirstChild("Head") then
            args[1] = target.Character.Head.Position
            return old(self, unpack(args))
        end
    end
    return old(self, ...)
end)

