    local lb = Instance.new("TextLabel")
    lb.Parent = MainFrame
    lb.BackgroundTransparency = 1
    lb.Size = UDim2.new(0,110,0,30)
    lb.Position = UDim2.new(0, 22, 0, 38 + ButtonY*37)
    lb.Text = name..": "..tostring(getfn())
    lb.TextColor3 = Color3.new(1,1,1)
    lb.Font = Enum.Font.GothamBold
    lb.TextSize = 18
    lb.TextXAlignment = Enum.TextXAlignment.Left
    lb.BorderSizePixel = 0

    local box = Instance.new("TextBox")
    box.Parent = MainFrame
    box.Size = UDim2.new(0, 46, 0, 24)
    box.Position = UDim2.new(0, 156, 0, 41 + ButtonY*37)
    box.Text = tostring(getfn())
    box.Font = Enum.Font.GothamBold
    box.TextSize = 15
    box.TextColor3 = Color3.new(1,1,1)
    box.BackgroundColor3 = Color3.new(0,0,0)
    box.BorderSizePixel = 0
    box.ClearTextOnFocus = true
    box.TextXAlignment = Enum.TextXAlignment.Center

    box.FocusLost:Connect(function()
        local v = tonumber(box.Text)
        if v and v >= min and v <= max then
            setfn(v)
            lb.Text = name..": "..v
        else
            box.Text = tostring(getfn())
        end
    end)
end

