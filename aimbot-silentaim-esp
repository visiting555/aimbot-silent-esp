local toggleY = 56
local toggleGap = 22
local toggleHeight = 42
local toggles = {}

local function makeToggle(text, settingKey, index)
    local btn = Instance.new("TextButton")
    btn.Name = settingKey.."Btn"
    btn.Size = UDim2.new(0.9,0,0,toggleHeight)
    btn.Position = UDim2.new(0.05,0,0,toggleY+((index-1)*(toggleHeight+toggleGap)))
    btn.BackgroundColor3 = Color3.fromRGB(0,0,0)
    btn.TextColor3 = Color3.fromRGB(255,255,255)
    btn.BorderSizePixel = 0
    btn.Font = Enum.Font.GothamBold
    btn.Text = text..": OFF"
    btn.TextSize = 21
    btn.AutoButtonColor = false
    btn.Parent = mainFrame

    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0,13)
    btnCorner.Parent = btn

    btn.MouseEnter:Connect(function()
        btn.BackgroundColor3 = Color3.fromRGB(30,30,30)
    end)
    btn.MouseLeave:Connect(function()
        btn.BackgroundColor3 = Color3.fromRGB(0,0,0)
    end)
    btn.MouseButton1Click:Connect(function()
        settings[settingKey] = not settings[settingKey]
        btn.Text = text..": "..(settings[settingKey] and "ON" or "OFF")
        if settingKey == "ESP" and not settings.ESP then
            clearEsp()
        end
    end)

    table.insert(toggles,btn)
    return btn
end

