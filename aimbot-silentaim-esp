-- Roblox Lua ESP + Aimbot + Silent Aim Hack Script with Menu

--[[
    Bu script, bir GUI menü ve işlevsel olarak ESP, Aimbot ve Silent Aim içerir.
    Menü üzerinden hileler açılıp kapatılır.
    Gelişmiş exploiter ortamlarında (SynapseX, Fluxus, KRNL, Electron vs.) sorunsuz çalışır.
    Mobil Roblox'ta ve vanilla clientta çalışmaz.
    Güvenliğiniz için scripti dikkatli kullanın.
]]

-- // Ayarlar
local settings = {
    ESP = false,
    Aimbot = false,
    SilentAim = false,
    ESP_Color = Color3.fromRGB(0,255,0),
    AimbotFOV = 80,
    AimbotSmooth = 0.2,
    AimbotHitPart = "Head", -- veya "Torso"
    SilentAimHitChance = 85,
}

-- // Oyuncu ve Hizmetler
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Mouse = LocalPlayer:GetMouse()
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera

-- // Lib: Simple ESP Drawer (ad-hoc)
local ESP_Boxes = {}

function CreateESPBox(character, color)
    local box = Drawing.new("Square")
    box.Visible = false
    box.Thickness = 1
    box.Color = color or Color3.fromRGB(0,255,0)
    box.Transparency = 1
    box.Filled = false
    ESP_Boxes[character] = box
    return box
end

function RemoveESPBox(character)
    if ESP_Boxes[character] then
        ESP_Boxes[character]:Remove()
        ESP_Boxes[character] = nil
    end
end

function UpdateESP()
    for _,plyr in pairs(Players:GetPlayers()) do
        if plyr ~= LocalPlayer and plyr.Character and plyr.Character:FindFirstChild("HumanoidRootPart") and plyr.Character:FindFirstChild("Humanoid") and plyr.Character.Humanoid.Health > 0 then
            local hrp = plyr.Character.HumanoidRootPart
            if not ESP_Boxes[plyr] then
                CreateESPBox(plyr, settings.ESP_Color)
            end
            local box = ESP_Boxes[plyr]
            local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
            if onScreen then
                local size = (Camera:WorldToViewportPoint(hrp.Position + Vector3.new(2,3,0)).X - Camera:WorldToViewportPoint(hrp.Position - Vector3.new(2,3,0)).X)
                box.Position = Vector2.new(pos.X - size/2, pos.Y - size/2)
                box.Size = Vector2.new(size, size*1.5)
                box.Color = settings.ESP_Color
                box.Visible = settings.ESP
            else
                box.Visible = false
            end
        else
            RemoveESPBox(plyr)
        end
    end
end

-- // Aimbot Fonksiyonu
function GetClosestPlayerToCursor()
    local closestPlayer, shortestDist = nil, math.huge
    for _,plyr in pairs(Players:GetPlayers()) do
        if plyr ~= LocalPlayer and plyr.Character and plyr.Character:FindFirstChild("HumanoidRootPart") and plyr.Character:FindFirstChild("Humanoid") and plyr.Character.Humanoid.Health > 0 then
            local part = plyr.Character:FindFirstChild(settings.AimbotHitPart) or plyr.Character:FindFirstChild("HumanoidRootPart")
            if part then
                local pos, onscreen = Camera:WorldToViewportPoint(part.Position)
                if onscreen then
                    local dist = (Vector2.new(pos.X,pos.Y) - Vector2.new(Mouse.X, Mouse.Y)).Magnitude
                    if dist < shortestDist and dist < settings.AimbotFOV then
                        shortestDist = dist
                        closestPlayer = plyr
                    end
                end
            end
        end
    end
    return closestPlayer
end

function Aimbot()
    local target = GetClosestPlayerToCursor()
    if target and target.Character then
        local part = target.Character:FindFirstChild(settings.AimbotHitPart) or target.Character:FindFirstChild("HumanoidRootPart")
        if part then
            local camPos = Camera.CFrame.Position
            local aimPos = part.Position
            local vector = (aimPos - camPos).Unit
            local newCFrame = CFrame.new(camPos, camPos + vector * 100)
            Camera.CFrame = Camera.CFrame:Lerp(newCFrame, settings.AimbotSmooth)
        end
    end
end

-- // SilentAim Fonksiyonu (Meta-table hook)
local SilentAimTarget = nil

function SelectSilentAimTarget()
    if math.random(0,99) < settings.SilentAimHitChance then
        SilentAimTarget = GetClosestPlayerToCursor()
    else
        SilentAimTarget = nil
    end
end

-- // Raycast manipulation
local __namecall
__namecall = hookmetamethod(game, "__namecall", function(self, ...)
    if not checkcaller() and settings.SilentAim and LocalPlayer.Character then
        local method = getnamecallmethod()
        if tostring(method) == "FindPartOnRayWithIgnoreList" or tostring(method) == "Raycast" then
            SelectSilentAimTarget()
            if SilentAimTarget and SilentAimTarget.Character and SilentAimTarget.Character:FindFirstChild(settings.AimbotHitPart) then
                local tPos = SilentAimTarget.Character[settings.AimbotHitPart].Position
                local args = {...}
                if method == "FindPartOnRayWithIgnoreList" and typeof(args[1]) == "Ray" then
                    local origin = args[1].Origin
                    local direction = (tPos - origin).Unit * 999
                    args[1] = Ray.new(origin, direction)
                    return __namecall(self, unpack(args))
                elseif method == "Raycast" then
                    args[2] = (tPos - args[1]).Unit * 999
                    return __namecall(self, unpack(args))
                end
            end
        end
    end
    return __namecall(self, ...)
end)

-- // Basit Menu
local ScreenGui = Instance.new("ScreenGui", game.CoreGui)
ScreenGui.Name = "ESP_Aimbot_Menu"

local Frame = Instance.new("Frame", ScreenGui)
Frame.Position = UDim2.new(0, 100, 0, 100)
Frame.Size = UDim2.new(0, 240, 0, 260)
Frame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
Frame.BorderSizePixel = 0
Frame.Active = true
Frame.Draggable = true

local UICorner = Instance.new("UICorner", Frame)
UICorner.CornerRadius = UDim.new(0,10)

local function CreateToggle(labelText, y, settingKey)
    local t = Instance.new("TextButton", Frame)
    t.Size = UDim2.new(0, 220, 0, 36)
    t.Position = UDim2.new(0,10,0,y)
    t.BackgroundColor3 = Color3.fromRGB(45,45,45)
    t.BorderSizePixel = 0
    t.TextColor3 = Color3.fromRGB(200,200,200)
    t.Font = Enum.Font.SourceSansBold
    t.TextSize = 22
    t.Text = labelText..": "..(settings[settingKey] and "ON" or "OFF")
    t.AutoButtonColor = false

    local function update()
        t.Text = labelText..": "..(settings[settingKey] and "ON" or "OFF")
    end

    t.MouseButton1Click:Connect(function()
        settings[settingKey] = not settings[settingKey]
        update()
    end)
    update()
end

local function CreateSlider(labelText, y, settingKey, min, max, increment)
    local label = Instance.new("TextLabel", Frame)
    label.Size = UDim2.new(0,220,0,22)
    label.Position = UDim2.new(0,10,0,y)
    label.BackgroundTransparency = 1
    label.TextColor3 = Color3.fromRGB(175,175,175)
    label.Font = Enum.Font.SourceSans
    label.TextSize = 16
    label.Text = labelText..": "..settings[settingKey]

    local slider = Instance.new("TextButton", Frame)
    slider.Size = UDim2.new(0,220,0,18)
    slider.Position = UDim2.new(0,10,0,y+24)
    slider.BackgroundColor3 = Color3.fromRGB(66,66,66)
    slider.Text = ""
    slider.AutoButtonColor = false

    local filled = Instance.new("Frame", slider)
    filled.BackgroundColor3 = Color3.fromRGB(95,205,77)
    filled.Size = UDim2.new((settings[settingKey]-min)/(max-min),1,0,18)
    filled.Position = UDim2.new(0,0,0,0)
    filled.BorderSizePixel = 0

    local dragging = false

    slider.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
        end
    end)
    slider.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    slider.MouseMoved:Connect(function(x)
        if dragging then
            local rel = math.clamp((x - slider.AbsolutePosition.X)/slider.AbsoluteSize.X, 0,1)
            local val = math.floor((min + (max - min) * rel)/increment+0.5)*increment
            settings[settingKey] = val
            filled.Size = UDim2.new((val-min)/(max-min),1,0,18)
            label.Text = labelText..": "..val
        end
    end)
end

CreateToggle("ESP", 15, "ESP")
CreateToggle("Aimbot", 60, "Aimbot")
CreateToggle("SilentAim", 105, "SilentAim")
CreateSlider("Aimbot FOV",150,"AimbotFOV",20,200,5)
CreateSlider("Aimbot Smooth",190,"AimbotSmooth",0,1,0.05)
CreateSlider("SilentAim HitChance",230,"SilentAimHitChance",0,100,1)

-- // Ana Döngü
RunService.RenderStepped:Connect(function()
    pcall(function()
    if settings.ESP then
        UpdateESP()
    else
        for plyr,box in pairs(ESP_Boxes) do
            box.Visible = false
        end
    end

    if settings.Aimbot and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
        Aimbot()
    end
    end)
end)

-- // GUI Toggle Shortcut (F4)
local UIS = game:GetService("UserInputService")
UIS.InputBegan:Connect(function(k, gpd)
    if not gpd and k.KeyCode == Enum.KeyCode.F4 then
        ScreenGui.Enabled = not ScreenGui.Enabled
    end
end)

