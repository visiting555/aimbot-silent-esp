-- ######## ESP #########
local drawings = {}

local function createBox(plr)
    pcall(function()
        if not drawings[plr] and plr and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local b = Drawing.new("Square")
            b.Color = Color3.fromRGB(59,220,128)
            b.Thickness = 2
            b.Filled = false
            b.Visible = false
            drawings[plr]=b
        end
    end)
end

local function removeBox(plr)
    pcall(function()
        if drawings[plr] then
            drawings[plr]:Remove()
            drawings[plr]=nil
        end
    end)
end

local function updateESP()
    for _,plr in ipairs(Players:GetPlayers()) do
        if plr~=LocalPlayer and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") and plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid.Health > 0 and settings.ESP then
            createBox(plr)
            local hrp = plr.Character.HumanoidRootPart
            local pos,onscr = Camera:WorldToViewportPoint(hrp.Position)
            local box = drawings[plr]
            if onscr and box then
                local TL = Camera:WorldToViewportPoint(hrp.Position + Vector3.new(-1.5,3,0))
                local BR = Camera:WorldToViewportPoint(hrp.Position + Vector3.new(1.5,-3,0))
                local w = math.abs(BR.X-TL.X)
                local h = math.abs(BR.Y-TL.Y)
                box.Size = Vector2.new(w,h)
                box.Position = Vector2.new(TL.X, TL.Y)
                box.Visible = true
            elseif box then
                box.Visible = false
            end
        else
            removeBox(plr)
        end
    end
end

-- ######## AIMBOT #########
local function getClosestTarget()
    local minDist = settings.AimbotFOV
    local target = nil
    for _,plr in ipairs(Players:GetPlayers()) do
        if plr~=LocalPlayer and plr.Character and plr.Character:FindFirstChild(settings.HitPart) and plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid.Health > 0 then
            local part = plr.Character[settings.HitPart]
            local pos, onscreen = Camera:WorldToViewportPoint(part.Position)
            if onscreen then
                local dist = (Vector2.new(Mouse.X, Mouse.Y) - Vector2.new(pos.X,pos.Y)).Magnitude
                if dist < minDist then
                    minDist = dist
                    target = part
                end
            end
        end
    end
    return target
end

local function doAimbot()
    if settings.Aimbot and UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
        local tgt = getClosestTarget()
        if tgt then
            local camPos = Camera.CFrame.Position
            local aimPos = tgt.Position
            local newCF = CFrame.new(camPos, aimPos)
            Camera.CFrame = Camera.CFrame:Lerp(newCF, settings.AimbotSmooth)
        end
    end
end

-- ########## SILENT AIM ###########
local SilentTarget
local function getSilentTarget()
    if math.random(1,100) <= settings.SilentHitChance then
        local minDist = settings.AimbotFOV
        local use = nil
        for _,plr in ipairs(Players:GetPlayers()) do
            if plr~=LocalPlayer and plr.Character and plr.Character:FindFirstChild(settings.HitPart) and plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid.Health > 0 then
                local part = plr.Character[settings.HitPart]
                local pos, onscr = Camera:WorldToViewportPoint(part.Position)
                if onscr then
                    local dist = (Vector2.new(Mouse.X, Mouse.Y) - Vector2.new(pos.X,pos.Y)).Magnitude
                    if dist < minDist then
                        minDist = dist
                        use = part
                    end
                end
            end
        end
        return use
    end
    return nil
end

do -- Hooklar local scope'da çalışır
    local rawmt = getrawmetatable(game)
    setreadonly(rawmt, false)
    local old; old = rawmt.__namecall
    rawmt.__namecall = newcclosure(function(self,...)
        local method = getnamecallmethod()
        local args = {...}
        if settings.SilentAim and not checkcaller() then
            if method == "FindPartOnRayWithIgnoreList" then
                local tgt = getSilentTarget()
                if tgt then
                    local p = args[1].Origin
                    local dir = (tgt.Position - p).Unit*999
                    args[1] = Ray.new(p, dir)
                    SilentTarget = tgt
                    return old(self, unpack(args))
                end
            elseif method == "Raycast" then
                local tgt = getSilentTarget()
                if tgt then
                    local pos = args[1]
                    args[2] = (tgt.Position - pos).Unit*999
                    SilentTarget = tgt
                    return old(self, unpack(args))
                end
            end
        end
        return old(self,...)
    end)
    setreadonly(rawmt, true)
end

