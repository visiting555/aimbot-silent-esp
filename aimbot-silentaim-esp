-- Takım kontrolü: Sadece düşmanlar!
local function isEnemy(target)
    local myTeam = LocalPlayer.Team
    local theirTeam = target.Team
    return myTeam == nil or theirTeam == nil or myTeam ~= theirTeam
end

local function getClosestEnemyToCursor()
    local closest,cldist = nil,FOV
    for _,plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and isEnemy(plr) and plr.Character and plr.Character:FindFirstChild("Head") then
            local h = plr.Character:FindFirstChild("Head")
            local humanoid = plr.Character:FindFirstChildWhichIsA("Humanoid")
            if humanoid and humanoid.Health > 0 then
                local pos,vis = Camera:WorldToViewportPoint(h.Position)
                if vis then
                    local dist = (Vector2.new(pos.X, pos.Y) - Vector2.new(Mouse.X, Mouse.Y)).Magnitude
                    if dist < cldist then
                        cldist = dist
                        closest = plr
                    end
                end
            end
        end
    end
    return closest
end

RunService.RenderStepped:Connect(function()
    if AimbotActive and not MenuOpen then
        local target = getClosestEnemyToCursor()
        if target and target.Character and target.Character:FindFirstChild("Head") then
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, target.Character.Head.Position)
        end
    end
end)

local success, rawmet = pcall(getrawmetatable, game)
if success then
    local __namecall = rawmet.__namecall
    setreadonly(rawmet, false)
    rawmet.__namecall = newcclosure(function(self, ...)
        local method = getnamecallmethod()
        if SilentAimActive and tostring(method)=="FindPartOnRayWithIgnoreList" then
            local target = getClosestEnemyToCursor()
            if target and target.Character and target.Character:FindFirstChild("Head") then
                local args = {...}
                args[1].Origin = Camera.CFrame.Position
                args[1].Direction = (target.Character.Head.Position - Camera.CFrame.Position).Unit * 999
                return __namecall(self, unpack(args))
            end
        end
        return __namecall(self, ...)
    end)
    setreadonly(rawmet, true)
end
