-- ANA HİLE DÖNGÜSÜ
RS.RenderStepped:Connect(function()
    if CHEATS.Aimbot and backdrop.Visible then
        local target = getClosestEnemy()
        if target then aimAt(target) end
    end
    if CHEATS.SilentAim then
        SilentAimTarget = getClosestEnemy()
    else
        SilentAimTarget = nil
    end
    if CHEATS.ESP and backdrop.Visible then
        stepESP()
    end
end)

