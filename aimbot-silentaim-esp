local function MakeSlider(lbl, setting, Y, min, max, step)
    local label = Instance.new("TextLabel", main)
    label.Size = UDim2.new(0,175,0,18)
    label.Position = UDim2.new(0,25,0,Y)
    label.BackgroundTransparency = 1
    label.Text = lbl..": "..tostring(settings[setting])
    label.Font = Enum.Font.Gotham
    label.TextColor3 = Color3.fromRGB(200,200,200)
    label.TextSize = 15
    label.TextXAlignment = Enum.TextXAlignment.Left

    local bar = Instance.new("Frame", main)
    bar.Size = UDim2.new(0,175,0,10)
    bar.Position = UDim2.new(0,25,0,Y+19)
    bar.BackgroundColor3 = Color3.fromRGB(43,44,52)
    bar.BorderSizePixel = 0
    Instance.new("UICorner",bar).CornerRadius = UDim.new(1,0)
    local fill = Instance.new("Frame",bar)
    fill.Size = UDim2.new((settings[setting]-min)/(max-min),0,1,0)
    fill.BackgroundColor3 = Color3.fromRGB(66,212,96)
    fill.BorderSizePixel = 0
    Instance.new("UICorner",fill).CornerRadius = UDim.new(1,0)

    local dragging = false

    bar.InputBegan:Connect(function(input)
        if input.UserInputType==Enum.UserInputType.MouseButton1 then dragging=true end
    end)
    bar.InputEnded:Connect(function(input)
        if input.UserInputType==Enum.UserInputType.MouseButton1 then dragging=false end
    end)
    bar.InputChanged:Connect(function(input)
        if input.UserInputType==Enum.UserInputType.MouseMovement and dragging then
            local percent = math.clamp((input.Position.X - bar.AbsolutePosition.X)/bar.AbsoluteSize.X,0,1)
            local val = min + (max-min)*percent
            val = step and (math.floor(val/step+0.5)*step) or math.floor(val+0.5)
            val = math.clamp(val,min,max)
            settings[setting] = val
            fill.Size = UDim2.new((val-min)/(max-min),0,1,0)
            label.Text = lbl..": "..tostring(val)
        end
    end)
    bar.MouseLeave:Connect(function() dragging=false end)
    sliderObjs[setting] = {label=label,fill=fill,min=min,max=max,lbl=lbl}
end

