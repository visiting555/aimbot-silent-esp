-- FULL ESP SYSTEM
local drawings = {}

local function createBox(plr)
    if plr and plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") and not drawings[plr] then
        local box = Drawing.new("Square")
        box.Visible = false
        box.Thickness = 2
        box.Color = Color3.fromRGB(59,220,128)
        box.Filled = false
        drawings[plr] = box
    end
end

local function removeBox(plr)
    if drawings[plr] then drawings[plr]:Remove() drawings[plr]=nil end
end

local function updateESP()
    for _,plr in ipairs(Players:GetPlayers()) do
        local ok = plr~=LocalPlayer and settings.ESP and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
        if ok and plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid.Health > 0 then
            createBox(plr)
            local hrp = plr.Character.HumanoidRootPart
            local TL = Camera:WorldToViewportPoint(hrp.Position + Vector3.new(-1.5,3,0))
            local BR = Camera:WorldToViewportPoint(hrp.Position + Vector3.new(1.5,-3,0))
            local TopL = TL
            local BotR = BR
            local onscreen = Camera:WorldToViewportPoint(hrp.Position)
            local box = drawings[plr]
            if onscreen.Z > 0 and box then
                box.Size = Vector2.new(math.abs(BotR.X-TopL.X),math.abs(BotR.Y-TopL.Y))
                box.Position = Vector2.new(TopL.X,TopL.Y)
                box.Visible = true
                box.Color = Color3.fromRGB(59,220,128)
            elseif box then
                box.Visible = false
            end
        else
            removeBox(plr)
        end
    end
end

-- FULL AIMBOT
local function getClosestTarget()
    local minDist = settings.AimbotFOV
    local target = nil
    for _,plr in ipairs(Players:GetPlayers()) do
        if plr~=LocalPlayer and plr.Character and plr.Character:FindFirstChild(settings.HitPart) and plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid.Health > 0 then
            local part = plr.Character[settings.HitPart]
            local pos,onscreen = Camera:WorldToViewportPoint(part.Position)
            if onscreen.Z>0 then
                local dist = (Vector2.new(Mouse.X,Mouse.Y)-Vector2.new(pos.X,pos.Y)).Magnitude
                if dist<minDist then
                    minDist = dist
                    target = part
                end
            end
        end
    end
    return target
end

local function doAimbot()
    if settings.Aimbot and UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
        local tgt = getClosestTarget()
        if tgt then
            local camPos = Camera.CFrame.Position
            local aimPos = tgt.Position
            local dir = (aimPos-camPos).Unit
            local newcf = CFrame.new(camPos,camPos+dir)
            Camera.CFrame = Camera.CFrame:Lerp(newcf,settings.AimbotSmooth)
        end
    end
end

-- FULL SILENT AIM (metatable hook, Ray, Raycast)
local function getSilentTarget()
    if settings.SilentAim and math.random(1,100) <= settings.SilentHitChance then
        local minDist = settings.AimbotFOV
        local use = nil
        for _,plr in ipairs(Players:GetPlayers()) do
            if plr~=LocalPlayer and plr.Character and plr.Character:FindFirstChild(settings.HitPart) and plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid.Health > 0 then
                local part = plr.Character[settings.HitPart]
                local pos,onscreen = Camera:WorldToViewportPoint(part.Position)
                if onscreen.Z>0 then
                    local dist = (Vector2.new(Mouse.X,Mouse.Y)-Vector2.new(pos.X,pos.Y)).Magnitude
                    if dist<minDist then
                        minDist = dist
                        use = part
                    end
                end
            end
        end
        return use
    end
    return nil
end

do
    local rawmt = getrawmetatable(game)
    setreadonly(rawmt, false)
    local old = rawmt.__namecall
    rawmt.__namecall = newcclosure(function(self,...)
        local method = getnamecallmethod()
        local args = {...}
        if settings.SilentAim and not checkcaller() then
            -- Roblox Classic Ray
            if method == "FindPartOnRayWithIgnoreList" and typeof(args[1]) == "Ray" then
                local tgt = getSilentTarget()
                if tgt then
                    local p = args[1].Origin
                    local dir = (tgt.Position - p).Unit * 1000
                    args[1] = Ray.new(p,dir)
                    return old(self,unpack(args))
                end
            -- New Raycast
            elseif method == "Raycast" and typeof(args[1])=="Vector3" and typeof(args[2])=="Vector3" then
                local tgt = getSilentTarget()
                if tgt then
                    local pos = args[1]
                    args[2] = (tgt.Position-pos).Unit * 1000
                    return old(self,unpack(args))
                end
            end
        end
        return old(self,...)
    end)
    setreadonly(rawmt,true)
end

