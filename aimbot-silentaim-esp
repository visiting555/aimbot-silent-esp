local function makeToggle(txt, settingKey, order)
    local Toggle = Instance.new("TextButton")
    Toggle.Name = txt .. "_Btn"
    Toggle.Text = txt..": OFF"
    Toggle.Font = Enum.Font.GothamBold
    Toggle.TextSize = 23
    Toggle.Size = UDim2.new(0.92,0,0,optionHeight)
    Toggle.Position = UDim2.new(0.04, 0, 0, yBase + (order-1)*(optionHeight+optionGap))
    Toggle.BackgroundColor3 = Color3.new(0,0,0)
    Toggle.TextColor3 = Color3.new(1,1,1)
    Toggle.AutoButtonColor = false
    Toggle.BorderSizePixel = 0
    Toggle.Parent = MenuFrame
    local roundT = Instance.new("UICorner")
    roundT.CornerRadius = UDim.new(0,13)
    roundT.Parent = Toggle
    
    Toggle.MouseEnter:Connect(function()
        Toggle.BackgroundColor3 = Color3.fromRGB(36,36,36)
    end)
    Toggle.MouseLeave:Connect(function()
        Toggle.BackgroundColor3 = Color3.new(0,0,0)
    end)
    Toggle.MouseButton1Click:Connect(function()
        settings[settingKey] = not settings[settingKey]
        Toggle.Text = txt..": "..(settings[settingKey] and "ON" or "OFF")
        if txt == "ESP" and not settings[settingKey] then clearEsp() end
    end)
    Toggle.Text = txt..": OFF"
    table.insert(toggles, Toggle)
    return Toggle
end

